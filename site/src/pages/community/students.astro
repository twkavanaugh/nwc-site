---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

// Students ministry page (/community/students). Translated from
// brand/prototype/page-students.jsx — all seven sections, light theme.
// React/onNav stripped; onNav/inert buttons → real <a href> or honestly inert.

const rhythms = [
  {
    tag: "Weekly · Sunday AM",
    title: "Sunday Mornings",
    lede: "Opening the Scriptures together.",
    body: "Students gather to open the Scriptures with teaching that is faithful and accessible. Our teaching rhythm alternates between books of the Bible and engaging relevant topics. Every message is Christ-centered — helping students see who Jesus is, what he has done, and how that changes everything.",
  },
  {
    tag: "Weekly · Sunday PM",
    title: "Sunday Evenings",
    lede: "Grow Groups & Real Talk.",
    body: "Students gather in Grow Groups by grade, mirroring adult community at North Wake. Every other week, students meet in 'Real Talk' Groups split by gender — a safe space for authenticity and vulnerability.",
  },
  {
    tag: "Annual · Spring",
    title: "Spring Mission Trip",
    lede: "Sent out together.",
    body: "Each spring our students serve alongside others — often partnering with North Wake church plants. These trips broaden worldviews, grow hearts of service, and build deep friendships among students.",
  },
  {
    tag: "Annual · Summer",
    title: "Camp",
    lede: "The Word, worship, friendships.",
    body: "Camp is an opportunity to hear the Word preached, grow in friendship, and worship alongside other churches. God has chosen to transform many students' lives through summer camp — and we're eager to see him keep working through faithful proclamation and strong community.",
  },
  {
    tag: "Annual · Fall",
    title: "Fall Retreat",
    lede: "Solitude with the Lord.",
    body: "One weekend each fall, students spend time in solitude with the Lord walking through a devotional — extended prayer, deep engagement with Scripture, and a step away from the hustle of ordinary life. A long-running student favorite.",
  },
];

const pillars = [
  { n: "01", h: "Proclaim Christ", b: "Faithful, Christ-centered teaching of Scripture — every week, every series." },
  { n: "02", h: "Build community", b: "Connecting students to meaningful relationships with peers and with mature adult leaders." },
  { n: "03", h: "Depend in prayer", b: "Trusting the Lord to transform students' lives through his Word, his Spirit, and his people." },
];
---

<Layout
  title="Students · North Wake Church"
  description="North Wake Church's ministry for students in 6th–12th grade — helping them grow into mature followers of Christ through faithful teaching of Scripture, community, and prayer."
>
  <!-- Breadcrumb (full-bleed chip bar — flush under nav, first in body) -->
  <Breadcrumb
    trail={[{ label: "Home", href: "/" }, { label: "Community", href: "/community/grow-groups" }, { label: "Students" }]}
    action={{ label: "All ministries", href: "/community/grow-groups" }}
  />

  <!-- Hero -->
  <section class="hero-sec">
    <div class="wrap">
      <div class="hero-grid">
        <div>
          <div class="eyebrow eyebrow--hero"><span class="dot"></span>Students · 6th – 12th grade</div>
          <h1 class="display-l hero-h1">
            Helping students grow into <span class="accent">mature followers of Christ.</span>
          </h1>
          <p class="lede hero-lede">
            Our student ministry exists to see students and their families know the
            love of God in Jesus Christ, grow in love for one another, and go in
            love to reach neighbors near and far.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="/visit">Visit a Sunday <span class="arr">→</span></a>
            {/* TODO: "Parent info" has no route yet — honestly inert until one exists. */}
            <button type="button" class="btn btn-ghost">Parent info</button>
          </div>
        </div>
        <div class="ph" style="aspect-ratio: 4 / 5;">
          <span class="ph-label">Students · gathering</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Heartbeat / Vision -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="dot"></span>The heartbeat</div>
          <h2 class="display-m vision-title">Our vision for students.</h2>
        </div>
        <p class="body right">
          As a ministry of North Wake Church, we extend the mission of the church —
          helping students grow into mature followers of Christ within the life of
          the local body.
        </p>
      </div>

      <div class="vision-grid">
        <div class="vision-col">
          <p>
            Our aim is to see students grow to maturity in Christ — hearts deeply
            saturated in the gospel, bearing fruit over time in their lives and in
            the lives of those around them.
          </p>
          <p>
            We pursue this by faithfully proclaiming Christ through the teaching of
            Scripture, connecting students to meaningful relationships with one
            another and with mature leaders in the church, and depending in prayer
            on the Lord to transform their lives.
          </p>
        </div>

        {/* Pull-quote figure — recurring pattern (Mature/Feed use similar). */}
        <figure class="quote-fig">
          <div class="mono quote-ref">Colossians 1:28–29</div>
          <blockquote class="quote-text">
            "Him we proclaim, warning everyone and teaching everyone with all wisdom,
            that we may present everyone mature in Christ. For this I toil, struggling
            with all his energy that he powerfully works within me."
          </blockquote>
        </figure>
      </div>
    </div>
  </section>

  <!-- Three pillars -->
  <section class="pillars-sec">
    <div class="wrap">
      <div class="eyebrow eyebrow--pillars"><span class="dot"></span>How we pursue it</div>
      <div class="pillars-grid">
        {
          pillars.map((p) => (
            <div>
              <div class="mono pillar-n">{p.n}</div>
              <h3 class="display-s pillar-h">{p.h}</h3>
              <p class="body pillar-b">{p.b}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Image strip -->
  <section class="strip-sec">
    <div class="wrap">
      <div class="strip-grid">
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Worship · candid</span></div>
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Real Talk group</span></div>
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Camp</span></div>
      </div>
    </div>
  </section>

  <!-- Regular rhythms -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow"><span class="dot"></span>Regular rhythms</div>
          <h2 class="display-m">When we gather.</h2>
        </div>
        <p class="body right">
          Discipleship happens through repetition. Across the week and across the
          year, here's how a student plugs in.
        </p>
      </div>

      {/* Hairline-gap card grid — recurring pattern (homepage community uses it). */}
      <div class="hairline-grid rhythms-grid">
        {
          rhythms.map((r) => (
            <article class="rhythm-card">
              <div class="mono rhythm-tag">{r.tag}</div>
              <h3 class="title rhythm-title">{r.title}</h3>
              <div class="rhythm-lede">{r.lede}</div>
              <p class="rhythm-body">{r.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="wrap-narrow cta-narrow">
      <div class="eyebrow eyebrow--cta"><span class="dot"></span>The next step</div>
      <h2 class="display-l cta-h">Come this Sunday.</h2>
      <p class="lede cta-lede">
        New students are welcome any week. We'll save you a seat — and we'll help
        your parents know what to expect, too.
      </p>
      <div class="cta-actions">
        <a class="btn btn-primary" href="/visit">Tell us you're coming <span class="arr">→</span></a>
        {/* TODO: no student-ministry email available yet — render inert, do not
            invent an address. Swap to a mailto: link once provided. */}
        <button type="button" class="btn btn-ghost">Email the student team</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Eyebrow color + accent dot (global .eyebrow .dot only sets color).
     NOTE: 2nd page to need this circle dot — promote to global.css (or an
     Eyebrow component) in a future pass; currently duplicated with index.astro. */
  .eyebrow {
    color: var(--ink-3);
    margin-bottom: 18px;
  }
  .eyebrow .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 10px;
    transform: translateY(-2px);
  }
  .eyebrow--hero {
    margin-bottom: 28px;
  }
  .eyebrow--pillars {
    margin-bottom: 36px;
  }
  .eyebrow--cta {
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
  }
  .accent {
    color: var(--accent);
  }

  /* Hero */
  .hero-sec {
    padding-top: 56px;
    padding-bottom: 0;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: end;
  }
  .hero-h1 {
    max-width: 16ch;
  }
  .hero-lede {
    margin-top: 28px;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* Heartbeat / Vision */
  .vision-title {
    max-width: 14ch;
  }
  .vision-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .vision-col p {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
  }
  .vision-col p:first-child {
    margin-top: 0;
  }
  .quote-fig {
    margin: 0;
    padding-left: 28px;
    border-left: 2px solid var(--accent);
  }
  .quote-ref {
    margin-bottom: 14px;
    color: var(--accent);
  }
  .quote-text {
    margin: 0;
    font-family: var(--display);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--ink-2);
  }

  /* Three pillars */
  .pillars-sec {
    background: var(--bg-2);
    padding-top: 80px;
    padding-bottom: 80px;
  }
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px;
  }
  .pillar-n {
    color: var(--accent);
    margin-bottom: 14px;
  }
  .pillar-h {
    font-weight: 500;
    margin-bottom: 14px;
  }
  .pillar-b {
    margin: 0;
    max-width: 32ch;
  }

  /* Image strip */
  .strip-sec {
    padding-top: 96px;
    padding-bottom: 0;
  }
  .strip-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 16px;
  }

  /* Regular rhythms */
  /* hairline mechanism now from global .hairline-grid; only columns stay local */
  .rhythms-grid {
    grid-template-columns: repeat(3, 1fr);
  }
  .rhythm-card {
    background: var(--bg);
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 300px;
  }
  .rhythm-tag {
    color: var(--accent);
  }
  .rhythm-title {
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.015em;
  }
  .rhythm-lede {
    color: var(--ink-2);
    font-weight: 500;
    font-size: 16px;
    line-height: 1.45;
  }
  .rhythm-body {
    margin: 0;
    color: var(--ink-3);
    font-size: 16px;
    line-height: 1.55;
  }

  /* CTA */
  .cta-narrow {
    text-align: center;
  }
  .cta-h {
    margin-bottom: 24px;
  }
  .cta-lede {
    margin: 0 auto;
    max-width: 48ch;
  }
  .cta-actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Mobile collapses — enhancement beyond the prototype (it had no mobile rules
     for these grids); prevents unusable multi-column layouts on phones. */
  @media (max-width: 880px) {
    .pillars-grid,
    .rhythms-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 720px) {
    .hero-grid,
    .vision-grid,
    .pillars-grid,
    .rhythms-grid,
    .strip-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
