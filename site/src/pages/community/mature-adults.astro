---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

// Mature Adults ministry page (/community/mature-adults).
// Translated from brand/prototype/page-mature.jsx.
// SECTION-GATED — built so far: 1) Breadcrumb, 2) Hero, 3) Opening conviction,
// 4) Our Heart, 5) Image strip, 6) What you'll experience.
// Sections 7–8 (join-us schedule, dark CTA) NOT built yet.

const longings = [
  "Friendships that grow",
  "Laughter shared often",
  "Faith that keeps deepening",
  "Encouragement, given and received",
  "Lasting relationships across the years",
];

const experiences = [
  {
    tag: "Connection",
    h: "Build meaningful friendships",
    b: "Real relationships with others who share similar life experiences and a common faith. The kind of friends you call when news — good or hard — comes.",
  },
  {
    tag: "Fun activities",
    h: "Joyful gatherings & outings",
    b: "Engaging mornings together, day trips, shared meals, and seasonal events. Laughter and good company are part of the design.",
  },
  {
    tag: "Welcoming community",
    h: "A warm, inviting atmosphere",
    b: "Everyone is valued and included. Whether you've been at North Wake for years or you walked in last Sunday, there's a seat for you.",
  },
  {
    tag: "Spiritual growth",
    h: "Deepening your walk with the Lord",
    b: "Encouragement, fellowship, and shared faith — strengthening one another in this rich, seasoned chapter of life.",
  },
];
---

<Layout
  title="Mature Adults · North Wake Church"
  description="Mature Adults at North Wake Church — fellowship, faith, and fun for a more seasoned season of life: meaningful connection, joyful activities, and deeper spiritual growth."
>
  <!-- 1. Breadcrumb -->
  <Breadcrumb
    trail={[{ label: "Home", href: "/" }, { label: "Community", href: "/community/grow-groups" }, { label: "Mature Adults" }]}
    action={{ label: "All ministries", href: "/community/grow-groups" }}
  />

  <!-- 2. Hero (ministry-template shape) -->
  <section class="mature-hero">
    <div class="wrap">
      <div class="mature-hero-grid">
        <div>
          <div class="eyebrow mature-hero-eyebrow"><span class="dot"></span>Mature Adults · Community ministry</div>
          <h1 class="display-l mature-h1">
            Growing in faith. Building friendships. <span class="mature-accent">Enjoying life together.</span>
          </h1>
          <p class="lede mature-lede">
            A place where fellowship, faith, and fun come together. Designed for those
            in a more seasoned season of life who desire meaningful connection, joyful
            activities, and deeper spiritual growth.
          </p>
          <div class="mature-hero-actions">
            {/* TODO: no clear route/email in the prototype — inert placeholders;
                wire once targets are confirmed. */}
            <button type="button" class="btn btn-primary">Join us this month <span class="arr">→</span></button>
            <button type="button" class="btn btn-ghost">Get in touch</button>
          </div>
        </div>
        <div class="ph" style="aspect-ratio: 4 / 5;">
          <span class="ph-label">Mature Adults · gathering</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Opening conviction (sans/display statement — NOT scripture/.serif) -->
  <section>
    <div class="wrap">
      <div class="mature-conviction">
        <div class="mono mature-conviction-label">Our conviction</div>
        <p class="mature-conviction-text">
          Every stage of life is a gift from God. This ministry celebrates the wisdom,
          experience, and vibrant spirit within our mature community.
        </p>
      </div>
    </div>
  </section>

  <!-- 4. Our Heart (bg-2 band; figure consumes global .pull-quote frame) -->
  <section class="mature-heart">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow mature-eyebrow"><span class="dot"></span>Our heart</div>
          <h2 class="display-m mature-heart-title">The heartbeat of this ministry is simple.</h2>
        </div>
        <p class="body right">
          A welcoming environment where friendships grow, laughter is shared, and our
          relationship with the Lord continues to deepen.
        </p>
      </div>

      <div class="mature-heart-grid">
        <div>
          <p class="body mature-heart-p">
            Through time together we encourage one another, build lasting relationships,
            and support each other in our faith journeys. Sundays are the doorway — but
            the deeper work of friendship and discipleship happens around tables, on
            outings, and in honest conversation.
          </p>
          <p class="body mature-heart-p">
            This is a season of life with much to give and much to receive. We carry
            decades of God's faithfulness with us — and we still have things to learn,
            friendships to make, and a Lord to know more deeply.
          </p>
        </div>

        {/* Pull-quote FRAME (global .pull-quote) wrapping a list — NOT scripture. */}
        <figure class="pull-quote mature-longings">
          <div class="mono mature-longings-label">What we long to see</div>
          <ul class="mature-longings-list">
            {longings.map((line) => (
              <li class="mature-longing">
                <span class="mature-longing-dot" aria-hidden="true"></span>
                <span>{line}</span>
              </li>
            ))}
          </ul>
        </figure>
      </div>
    </div>
  </section>

  <!-- 5. Image strip -->
  <section class="mature-strip">
    <div class="wrap">
      <div class="mature-strip-grid">
        <div class="ph" style="aspect-ratio: 4 / 5;"><span class="ph-label">Around the table</span></div>
        <div class="ph" style="aspect-ratio: 16 / 10;"><span class="ph-label">Outings together</span></div>
        <div class="ph" style="aspect-ratio: 4 / 5;"><span class="ph-label">Studying the Word</span></div>
      </div>
    </div>
  </section>

  <!-- 6. What you'll experience (consumes global .hairline-grid; cells page-local) -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow mature-eyebrow"><span class="dot"></span>What you'll experience</div>
          <h2 class="display-m">Four things you can count on.</h2>
        </div>
        <p class="body right">
          Connection, fun, welcome, and growth — woven into every gathering. Come once
          and see for yourself.
        </p>
      </div>

      <div class="hairline-grid mature-exp-grid">
        {
          experiences.map((r, i) => (
            <article class="mature-exp-card">
              <div class="mature-exp-head">
                <span class="display-s mature-exp-num">0{i + 1}</span>
                <span class="mono mature-exp-tag">{r.tag}</span>
              </div>
              <h3 class="title mature-exp-title">{r.h}</h3>
              <p class="mature-exp-body">{r.b}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 7. Join Us — schedule card (bg-2 band) -->
  <section class="mature-join">
    <div class="wrap">
      <div class="mature-join-grid">
        <div>
          <div class="eyebrow mature-join-eyebrow"><span class="dot"></span>Join us</div>
          <h2 class="display-l mature-join-title">
            Twice a month, <span class="mature-accent">mornings together.</span>
          </h2>
          <p class="lede mature-join-lede">
            Whether you're looking to meet new friends, participate in enjoyable
            activities, or simply spend time with others who share your faith — this is
            a place for you. Come grow in community, deepen your relationship with the
            Lord, and enjoy the journey together.
          </p>
          <div class="mature-join-actions">
            {/* TODO: no real RSVP route/email in the prototype — inert placeholders. */}
            <button type="button" class="btn btn-primary">RSVP for the next gathering <span class="arr">→</span></button>
            <button type="button" class="btn btn-ghost">Email the team</button>
          </div>
        </div>

        <div class="mature-schedule-card">
          <div class="mono mature-schedule-label">When we gather</div>
          <div class="mature-schedule-grid">
            <div class="small mature-schedule-key">Cadence</div>
            <div class="title mature-schedule-val">Twice a month</div>
            <div class="mature-schedule-div"></div>
            <div class="small mature-schedule-key">Days</div>
            <div class="title mature-schedule-val">1st &amp; 3rd Tuesdays</div>
            <div class="mature-schedule-div"></div>
            <div class="small mature-schedule-key">Time</div>
            <div class="title mature-schedule-val">Mornings</div>
            <div class="mature-schedule-div"></div>
            <div class="small mature-schedule-key">Where</div>
            <div class="title mature-schedule-val">North Wake Church</div>
          </div>
          <div class="mature-schedule-foot">
            <div>
              <div class="small mature-schedule-next-label">Next gathering</div>
              <div class="body mature-schedule-next">Tuesday, May 5 · 10:00 AM</div>
            </div>
            <span class="mature-schedule-arr" aria-hidden="true">→</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. CTA (DARK band — inverse tokens, no raw white literals) -->
  <section class="mature-cta">
    <div class="wrap-narrow mature-cta-inner">
      <div class="eyebrow mature-cta-eyebrow"><span class="dot"></span>You're welcome here</div>
      <h2 class="display-l mature-cta-title">Come, and bring a friend.</h2>
      <p class="lede mature-cta-lede">
        Every stage of life is a gift. We'd love to share this one with you — around the
        table, in the Word, and out enjoying everything God has given.
      </p>
      <div class="mature-cta-actions">
        {/* TODO: inert placeholders — no real RSVP route / team email in prototype. */}
        <button type="button" class="btn btn-accent">RSVP <span class="arr">→</span></button>
        <button type="button" class="btn mature-cta-ghost">Email the team</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .mature-hero {
    padding: 56px 0 0;
  }
  .mature-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
    align-items: end;
  }
  .mature-hero-eyebrow {
    margin-bottom: 28px;
  }
  .mature-h1 {
    max-width: 16ch;
  }
  /* Non-italic accent span (no global accent-color utility; .em-accent adds italic). */
  .mature-accent {
    color: var(--accent);
  }
  .mature-lede {
    margin-top: 28px;
  }
  .mature-hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* Opening conviction — sans/display statement (NOT a serif scripture block). */
  .mature-conviction {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 56px;
    align-items: start;
    max-width: 1100px;
    margin: 0 auto;
  }
  .mature-conviction-label {
    color: var(--accent);
    padding-top: 12px;
  }
  .mature-conviction-text {
    margin: 0;
    font-family: var(--display);
    font-weight: 400;
    font-size: 38px;
    line-height: 1.25;
    letter-spacing: -0.025em;
    color: var(--ink);
    text-wrap: balance;
  }

  /* 4. Our Heart — bg-2 band */
  .mature-heart {
    background: var(--bg-2);
  }
  .mature-eyebrow {
    margin-bottom: 18px;
  }
  .mature-heart-title {
    max-width: 16ch;
  }
  .mature-heart-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .mature-heart-p {
    font-size: 18px;
    line-height: 1.65;
  }
  .mature-heart-p:first-child {
    margin-top: 0;
  }
  /* .mature-longings consumes global .pull-quote (accent left border + padding).
     Inner label + list are page-local (a list, NOT scripture). */
  .mature-longings {
    margin: 0;
  }
  .mature-longings-label {
    margin-bottom: 14px;
    color: var(--accent);
  }
  .mature-longings-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .mature-longing {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 14px;
    align-items: baseline;
    font-family: var(--display);
    font-size: 19px;
    line-height: 1.45;
    font-weight: 500;
    color: var(--ink-2);
    letter-spacing: -0.01em;
  }
  .mature-longing-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    transform: translateY(-3px);
  }

  /* 5. Image strip */
  .mature-strip {
    padding: 16px 0 0;
  }
  .mature-strip-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 16px;
  }

  /* 6. What you'll experience — grid mechanism from global .hairline-grid;
     page-local class holds only columns; cells are page-local (not .kids/.feed card). */
  .mature-exp-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  .mature-exp-card {
    background: var(--bg);
    padding: 44px 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-height: 240px;
  }
  .mature-exp-head {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .mature-exp-num {
    color: var(--accent);
    font-weight: 500;
  }
  .mature-exp-tag {
    color: var(--ink-3);
  }
  .mature-exp-title {
    font-weight: 500;
    font-size: 26px;
    letter-spacing: -0.02em;
    margin-top: 0;
  }
  .mature-exp-body {
    margin: 0;
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* 7. Join Us — schedule card (bg-2 band) */
  .mature-join {
    background: var(--bg-2);
  }
  .mature-join-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 64px;
    align-items: center;
  }
  .mature-join-eyebrow {
    margin-bottom: 24px;
  }
  .mature-join-title {
    max-width: 14ch;
    margin-bottom: 24px;
  }
  .mature-join-lede {
    margin-bottom: 32px;
  }
  .mature-join-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  /* Page-local schedule card (own padding/structure; not .kids-card/.feed-card). */
  .mature-schedule-card {
    background: var(--bg);
    border: 1px solid var(--line-strong);
    padding: 36px 36px 32px;
    display: grid;
    gap: 0;
  }
  .mature-schedule-label {
    color: var(--accent);
    margin-bottom: 20px;
  }
  .mature-schedule-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 20px 28px;
    align-items: baseline;
  }
  .mature-schedule-key {
    color: var(--ink-3);
  }
  .mature-schedule-val {
    font-weight: 500;
    font-size: 22px;
  }
  .mature-schedule-div {
    grid-column: 1 / -1;
    height: 1px;
    background: var(--line);
    margin: 4px 0;
  }
  .mature-schedule-foot {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .mature-schedule-next-label {
    color: var(--ink-3);
    margin-bottom: 2px;
  }
  .mature-schedule-next {
    color: var(--ink);
    font-weight: 500;
  }
  .mature-schedule-arr {
    color: var(--accent);
  }

  /* 8. CTA — DARK band, inverse semantic tokens only (no raw white). */
  .mature-cta {
    background: var(--bg-inverse);
    color: var(--ink-on-inverse);
  }
  .mature-cta-inner {
    text-align: center;
  }
  .mature-cta-eyebrow {
    color: var(--ink-on-inverse-2);
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
  }
  .mature-cta-title {
    color: var(--ink-on-inverse);
    margin-bottom: 24px;
  }
  .mature-cta-lede {
    color: var(--ink-on-inverse-2);
    margin: 0 auto;
    max-width: 50ch;
  }
  .mature-cta-actions {
    margin-top: 36px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  /* Ghost button on dark — uses --border-on-inverse (its designed use case). */
  .mature-cta-ghost {
    background: transparent;
    color: var(--ink-on-inverse);
    border: 1px solid var(--border-on-inverse);
  }

  /* Mobile collapses — enhancement beyond the prototype (consistent precedent). */
  @media (max-width: 720px) {
    .mature-hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .mature-conviction {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .mature-heart-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .mature-strip-grid {
      grid-template-columns: 1fr;
    }
    .mature-exp-grid {
      grid-template-columns: 1fr;
    }
    .mature-join-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
