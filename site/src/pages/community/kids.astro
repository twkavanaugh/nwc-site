---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import { BUSINESS } from "../../data/business";

// Worship service times derive from BUSINESS.serviceTimes (single source of truth).
const svc = BUSINESS.serviceTimes;
const compactHour = (t: string) => t.replace(/:00\b/, ""); // "9:00 AM" -> "9 AM"; "10:45 AM" unchanged

// Kids ministry page (/community/kids). Translated from brand/prototype/page-kids.jsx.
// COMPLETE — all 10 sections: 1) Breadcrumb, 2) Hero, 3) Sunday schedule,
// 4) Mission verse, 5) Image strip, 6) Curriculum, 7) Child dedication,
// 8) Children in worship, 9) Health & safety, 10) CTA.

const illness = [
  "Fever (any oral temperature over 100°)",
  "Vomiting or diarrhea",
  "Runny nose with yellow / green discharge",
  "Persistent cough",
  "Sore throat",
  "COVID symptoms",
  "Croup",
  "Unexplained rash",
  "Childhood disease symptoms — scarlet fever, measles, mumps, chicken pox, whooping cough",
  "Skin infection — impetigo, boils, ringworm",
  "Eye infection — pink-eye or drainage",
  "Lice, or evidence of lice / nits within the past 2 weeks",
];

const purposes = [
  {
    n: "01",
    h: "Parents commit publicly.",
    b: "Parents commit themselves to raise their children in the way of the Lord, inviting the encouragement, accountability, and prayer support of the congregation.",
    ref: "Eph. 6:4",
  },
  {
    n: "02",
    h: "Parents present their children to the Lord.",
    b: "Acknowledging that children are a gift from the Lord — and hoping in God to use them mightily to bring honor to his name and to expand his kingdom.",
    ref: "1 Sam. 1:27–28",
  },
  {
    n: "03",
    h: "Parents seek God's blessing.",
    b: "Following the example of those who brought little children to Jesus — publicly seeking his blessing on the next generation.",
    ref: "Mark 10:13–16",
  },
];
---

<Layout
  title="Kids · North Wake Church"
  description="North Wake Kids (babies–5th grade) gives every child a place to know God in Jesus, grow in love for one another, and be sent to share that love with friends and family."
>
  <!-- 1. Breadcrumb (full-bleed chip bar — flush under nav, first in body) -->
  <Breadcrumb
    trail={[{ label: "Home", href: "/" }, { label: "Community", href: "/community/grow-groups" }, { label: "Kids" }]}
    action={{ label: "All ministries", href: "/community/grow-groups" }}
  />

  <!-- 2. Hero (mirrors the students hero structure) -->
  <section class="kids-hero">
    <div class="wrap">
      <div class="kids-hero-grid">
        <div>
          <div class="eyebrow kids-hero-eyebrow"><span class="dot"></span>North Wake Kids · Babies – 5th grade</div>
          <h1 class="display-l kids-h1">
            Know the love of Jesus. <span class="kids-accent">Grow in love for one another. Go to share it.</span>
          </h1>
          <p class="lede kids-lede">
            North Wake Kids exists to give every child a place to know God in Jesus,
            grow in love for one another, and be sent out to share that love with
            friends and family.
          </p>
          <div class="kids-hero-actions">
            <a class="btn btn-primary" href="/visit">Plan your visit <span class="arr">→</span></a>
            {/* TODO: "Email the kids team" — prototype provides children@northwake.com
                (sections 7/10, not yet built, UNVERIFIED). Inert until verified, then
                wire to mailto:. */}
            <button type="button" class="btn btn-ghost">Email the kids team</button>
          </div>
        </div>
        <div class="ph" style="aspect-ratio: 4 / 5;">
          <span class="ph-label">Kids ministry · candid</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Sunday schedule (hairline-gap card grid idiom) -->
  <section class="kids-schedule">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow kids-eyebrow"><span class="dot"></span>Sunday mornings</div>
          <h2 class="display-m kids-sched-title">Two services. Both built for kids.</h2>
        </div>
        <p class="body right">
          Each Sunday, trained teachers gather kids to learn more about our great God
          — through age-appropriate teaching, worship, and play.
        </p>
      </div>

      <div class="hairline-grid kids-sched-grid">
        <article class="kids-sched-card">
          <div class="mono kids-sched-label">Service · {svc[0]}</div>
          <h3 class="display-s kids-sched-hour">{compactHour(svc[0])} hour</h3>
          <ul class="kids-sched-list">
            <li class="kids-sched-row">
              <span class="mono kids-sched-agelabel">Babies – Pre-K</span>
              <span class="body kids-sched-desc">Classes by age group with trained teachers.</span>
            </li>
            <li class="kids-sched-row">
              <span class="mono kids-sched-agelabel">K – 5th</span>
              <span class="body kids-sched-desc">Kid's Worship Hour — currently <em>Roamin' Through Romans</em>.</span>
            </li>
          </ul>
        </article>
        <article class="kids-sched-card">
          <div class="mono kids-sched-label">Service · {svc[1]}</div>
          <h3 class="display-s kids-sched-hour">{compactHour(svc[1])} hour</h3>
          <ul class="kids-sched-list">
            <li class="kids-sched-row">
              <span class="mono kids-sched-agelabel">Babies – 5th</span>
              <span class="body kids-sched-desc">Full classes for every age, using The Gospel Project curriculum.</span>
            </li>
            <li class="kids-sched-row">
              <span class="mono kids-sched-agelabel">Parents</span>
              <span class="body kids-sched-desc">Drop kids off, then head into the worship service together.</span>
            </li>
          </ul>
        </article>
      </div>
    </div>
  </section>

  <!-- 4. Mission verse + statement (bg-2 band) — DESIGN CHANGE: verse leads in the
       wider column, set in .serif (Newsreader) at a larger responsive size. -->
  <section class="kids-mission">
    <div class="wrap">
      <div class="kids-mission-grid">
        <figure class="pull-quote kids-verse-fig">
          <div class="mono kids-verse-ref">Psalm 78:6</div>
          <blockquote class="serif kids-verse">"…that the next generation might know."</blockquote>
        </figure>

        <div>
          <div class="eyebrow kids-eyebrow"><span class="dot"></span>The heartbeat</div>
          <h2 class="display-m kids-mission-title">Know. Grow. Go.</h2>
          <p class="body kids-mission-body">
            We want kids to <strong>know</strong> the love of God in Jesus,
            <strong>grow</strong> in love for one another, and be sent to
            <strong>go</strong> share the love of Jesus with friends and family. Each
            Sunday morning brings children together with trained teachers to learn
            more about our great God.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Image strip -->
  <section class="kids-strip">
    <div class="wrap">
      <div class="kids-strip-grid">
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Classroom</span></div>
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Kid's worship</span></div>
        <div class="ph" style="aspect-ratio: 4 / 3;"><span class="ph-label">Drop-off</span></div>
      </div>
    </div>
  </section>

  <!-- 6. Curriculum (bordered card grid) -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow kids-eyebrow"><span class="dot"></span>What we're studying</div>
          <h2 class="display-m kids-curric-title">Curriculum.</h2>
        </div>
        <p class="body right">
          Two strong, gospel-centered tracks running in parallel — chosen so kids and
          parents can talk through the same big story together.
        </p>
      </div>

      <div class="kids-cardgrid">
        <article class="kids-card">
          <div class="mono kids-card-label">Kid's Worship · K–5th · {compactHour(svc[0])}</div>
          <h3 class="display-s kids-card-title">Roamin' Through Romans</h3>
          <p class="body kids-card-body">
            Kids walk through the book of Romans together — the same letter the whole
            church is preaching through this season.
          </p>
        </article>
        <article class="kids-card">
          <div class="mono kids-card-label">All preschool · {compactHour(svc[0])} &nbsp;·&nbsp; All classes · {compactHour(svc[1])}</div>
          <h3 class="display-s kids-card-title">The Gospel Project</h3>
          <p class="body kids-card-body kids-card-body--gap">
            A weekly Bible study that helps kids dive deep into the big story of the
            Bible — God's plan to rescue his people through his Son, Jesus Christ.
          </p>
          {/* TODO: track links have no targets in the prototype — inert placeholders;
              wire to the real Gospel Project track URLs once provided. */}
          <div class="kids-track-links">
            <span class="mono kids-track-link">Preschool track →</span>
            <span class="mono kids-track-link">Grade school track →</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- 7. Child dedication (DARK band — inverse tokens, no raw white literals) -->
  <section class="kids-dedication">
    <div class="wrap">
      <div class="kids-dedication-grid">
        <div>
          <div class="eyebrow kids-dedication-eyebrow"><span class="dot"></span>Upcoming · May 10, 2026</div>
          <h2 class="display-l kids-dedication-title">Child dedication.</h2>
          <p class="body kids-dedication-lead">
            On Sunday, May 10, families have the opportunity in both services to
            dedicate their children. Email the kids team with your child's full name
            and the service hour you'd like to attend.
          </p>
          <div class="kids-dedication-contact">
            {/* TODO: UNVERIFIED church email — shown as text only, NOT a live mailto.
                Wire to mailto:children@northwake.com once the church confirms it. */}
            <div class="mono kids-dedication-email">children@northwake.com</div>
            {/* TODO: placeholder — needs the real photo-release-form link. */}
            <span class="mono kids-dedication-formlink">Photo release form →</span>
          </div>
        </div>

        <div>
          <p class="body kids-dedication-intro">
            At North Wake we greatly value the role parents and the church body play
            in raising children to be wholehearted followers of Christ. The public
            dedication of children serves three purposes:
          </p>

          <div class="kids-purposes">
            {
              purposes.map((p) => (
                <div class="kids-purpose">
                  <div class="mono kids-purpose-n">{p.n}</div>
                  <div>
                    <h3 class="title kids-purpose-h">{p.h}</h3>
                    <p class="kids-purpose-b">{p.b}</p>
                    <span class="mono kids-purpose-ref">{p.ref}</span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. Children in worship (bordered cards — reuses .kids-card*) -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow kids-eyebrow"><span class="dot"></span>Children in worship</div>
          <h2 class="display-m kids-worship-title">Practical help during the service.</h2>
        </div>
        <p class="body right">
          Two small things that make a big difference for parents on Sunday morning.
        </p>
      </div>

      <div class="kids-cardgrid">
        <article class="kids-card">
          <div class="mono kids-card-label">Off the worship center</div>
          <h3 class="display-s kids-card-title">Mother's Room</h3>
          <p class="body kids-card-body">
            A private room connected to the worship center for feeding, soothing, or
            stepping out with a fussy little one. A speaker keeps the music and message
            playing throughout.
          </p>
        </article>
        <article class="kids-card">
          <div class="mono kids-card-label">On the lobby table</div>
          <h3 class="display-s kids-card-title">Worship Guide for Kids</h3>
          <p class="body kids-card-body">
            Grab a paper guide and a pack of crayons on your way in to help your kids
            engage with the service alongside you.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- 9. Health & safety (bg-2 band — reuses .kids-card*, filled on the band) -->
  <section class="kids-safety">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow kids-eyebrow"><span class="dot"></span>Health &amp; safety</div>
          <h2 class="display-m kids-safety-title">Your child's safety, taken seriously.</h2>
        </div>
        <p class="body right">
          We take safety and security in kids ministry seriously — for parents, for
          kids, and for the volunteers who love them well.
        </p>
      </div>

      <div class="kids-cardgrid">
        <article class="kids-card">
          <div class="mono kids-card-label">Accreditation in process</div>
          <h3 class="display-s kids-card-title">ECAP — Evangelical Council for Abuse Prevention</h3>
          <p class="body kids-card-body kids-card-body--gap">
            North Wake is currently in the accreditation process with ECAP. Our Child
            Safety Team oversees and supports volunteers in implementing our child
            protection policies.
          </p>
          {/* TODO: UNVERIFIED church email — text only, no live mailto until confirmed. */}
          <div class="mono kids-card-email">childsafety@northwake.com</div>
        </article>
        <article class="kids-card">
          <div class="mono kids-card-label">Illness policy</div>
          <h3 class="display-s kids-card-title">Stay home if&nbsp;…</h3>
          <p class="body kids-card-body kids-card-body--gap">
            Children should not be in Sunday school if they have shown any of the
            following within the previous 24 hours.
          </p>
          <ul class="kids-illness-list">
            {illness.map((item) => <li class="kids-illness-item">{item}</li>)}
          </ul>
          <p class="mono kids-illness-note">When in doubt, sit an extra week out.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- 10. CTA — connect (centered wrap-narrow, mirrors students CTA) -->
  <section>
    <div class="wrap-narrow kids-cta">
      <div class="eyebrow kids-cta-eyebrow"><span class="dot"></span>Connect with us</div>
      <h2 class="display-l kids-cta-title">Questions? Just ask.</h2>
      <p class="lede kids-cta-lede">
        We'd love to help you plan your first Sunday — or answer anything about
        classes, drop-off, or what to expect.
      </p>
      <div class="kids-cta-actions">
        {/* TODO: UNVERIFIED email — inert until confirmed; then wire mailto:children@northwake.com. */}
        <button type="button" class="btn btn-primary">Email children@northwake.com <span class="arr">→</span></button>
        {/* TODO: placeholder — needs the real @northwakekids social URL. */}
        <button type="button" class="btn btn-ghost">Follow @northwakekids</button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .kids-hero {
    padding: 56px 0 0;
  }
  .kids-hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 64px;
    align-items: end;
  }
  .kids-hero-eyebrow {
    margin-bottom: 28px;
  }
  .kids-h1 {
    max-width: 16ch;
  }
  /* Non-italic accent span (no global accent-color utility exists; .em-accent
     would add italic, which the prototype hero does NOT use). */
  .kids-accent {
    color: var(--accent);
  }
  .kids-lede {
    margin-top: 28px;
  }
  .kids-hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* Section separator — hero → 64px gap → hairline → 96px gap → schedule.
     CANDIDATE shared "section-separator" pattern (students has a similar
     hero→section seam); kept page-local this pass. */
  .kids-schedule {
    margin-top: 64px;
    padding-top: 96px;
    border-top: 1px solid var(--line);
  }

  /* Sunday schedule — hairline-gap card grid (same idiom as students rhythms /
     homepage community; kept page-local, recurrence flagged for a later pass). */
  .kids-eyebrow {
    margin-bottom: 18px;
  }
  .kids-sched-title {
    max-width: 14ch;
  }
  /* hairline mechanism now from global .hairline-grid; only columns stay local */
  .kids-sched-grid {
    grid-template-columns: 1fr 1fr;
  }
  .kids-sched-card {
    background: var(--bg);
    padding: 44px 40px 40px;
  }
  .kids-sched-label {
    color: var(--accent);
    margin-bottom: 18px;
  }
  .kids-sched-hour {
    font-weight: 500;
    margin-bottom: 18px;
    letter-spacing: -0.015em;
  }
  .kids-sched-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .kids-sched-row {
    display: flex;
    gap: 16px;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding-top: 14px;
  }
  .kids-sched-agelabel {
    color: var(--ink-3);
    min-width: 110px;
  }
  .kids-sched-desc {
    margin: 0;
  }

  /* 4. Mission verse + statement (bg-2 band) */
  .kids-mission {
    background: var(--bg-2);
    padding: 96px 0;
  }
  /* DESIGN CHANGE: flipped from prototype's 1fr 1.3fr → verse gets the WIDER
     (1.3fr) lead column; statement sits in the narrower 1fr column. */
  .kids-mission-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 80px;
    align-items: start;
  }
  .kids-verse-fig {
    margin: 0;
  }
  .kids-verse-ref {
    margin-bottom: 14px;
    color: var(--accent);
  }
  /* Scripture treatment — Newsreader (.serif), upright, lighter weight, larger
     responsive size. SCRIPTURE-EXTRACTION CANDIDATE: promote .kids-verse to a
     shared "scripture" class when the 2nd verse occurrence appears (mature/feed). */
  .kids-verse {
    margin: 0;
    font-weight: 400;
    font-size: clamp(34px, 4vw, 48px);
    line-height: 1.3;
    letter-spacing: -0.02em;
    color: var(--ink);
  }
  .kids-mission-title {
    max-width: 16ch;
    margin-bottom: 24px;
  }
  .kids-mission-body {
    font-size: 18px;
    line-height: 1.65;
    color: var(--ink-2);
    max-width: 52ch;
  }

  /* 5. Image strip */
  .kids-strip {
    padding: 96px 0 0;
  }
  .kids-strip-grid {
    display: grid;
    grid-template-columns: 1fr 2fr 1fr;
    gap: 16px;
  }

  /* 6. Curriculum — bordered card grid.
     NOTE: this bordered-card pattern recurs within kids (sections 6, 8, 9) and is a
     candidate cross-page pattern; kept page-local (.kids-card*) for now. */
  .kids-curric-title {
    max-width: 14ch;
  }
  .kids-cardgrid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .kids-card {
    border: 1px solid var(--line-strong);
    padding: 40px 36px;
  }
  .kids-card-label {
    color: var(--accent);
    margin-bottom: 14px;
  }
  .kids-card-title {
    font-weight: 500;
    margin-bottom: 16px;
    letter-spacing: -0.015em;
  }
  .kids-card-body {
    margin: 0;
    color: var(--ink-2);
  }
  .kids-card-body--gap {
    margin-bottom: 18px;
  }
  .kids-track-links {
    display: flex;
    gap: 18px;
    font-size: 14px;
  }
  .kids-track-link {
    color: var(--accent);
  }

  /* 7. Child dedication — DARK band, inverse semantic tokens only (no raw white). */
  .kids-dedication {
    background: var(--bg-inverse);
    color: var(--ink-on-inverse);
    padding: 96px 0;
  }
  .kids-dedication-grid {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 80px;
    align-items: start;
  }
  .kids-dedication-eyebrow {
    margin-bottom: 18px;
    color: var(--ink-on-inverse-2);
  }
  .kids-dedication-title {
    color: var(--ink-on-inverse);
    margin-bottom: 24px;
    max-width: 12ch;
  }
  .kids-dedication-lead {
    color: var(--ink-on-inverse-2);
    max-width: 38ch;
    font-size: 17px;
    line-height: 1.65;
  }
  .kids-dedication-contact {
    margin-top: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .kids-dedication-email {
    color: var(--accent);
  }
  .kids-dedication-formlink {
    color: var(--ink-on-inverse-2);
  }
  .kids-dedication-intro {
    color: var(--ink-on-inverse);
    font-size: 17px;
    line-height: 1.65;
    margin-top: 0;
  }
  .kids-purposes {
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
  }
  .kids-purpose {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 24px;
    align-items: start;
    border-top: 1px solid var(--line-on-inverse);
    padding-top: 22px;
  }
  .kids-purpose-n {
    color: var(--accent);
  }
  .kids-purpose-h {
    color: var(--ink-on-inverse);
    font-weight: 500;
    margin-top: 0;
    margin-bottom: 8px;
  }
  .kids-purpose-b {
    margin: 0 0 8px;
    color: var(--ink-on-inverse-2);
    font-size: 15px;
    line-height: 1.6;
  }
  .kids-purpose-ref {
    color: var(--ink-on-inverse-2);
  }

  /* 8. Children in worship — reuses .kids-card* / .kids-cardgrid (no divergence) */
  .kids-worship-title {
    max-width: 16ch;
  }

  /* 9. Health & safety — bg-2 band; cards reuse .kids-card* but get a --bg fill
     to stand out against the band (the only divergence from sections 6/8). */
  .kids-safety {
    background: var(--bg-2);
    padding: 96px 0;
  }
  .kids-safety-title {
    max-width: 16ch;
  }
  .kids-safety .kids-card {
    background: var(--bg);
  }
  .kids-card-email {
    color: var(--accent);
  }
  .kids-illness-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 24px;
    font-size: 14px;
    color: var(--ink-2);
  }
  .kids-illness-item {
    padding-left: 14px;
    position: relative;
    line-height: 1.5;
  }
  .kids-illness-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 9px;
    width: 6px;
    height: 1px;
    background: var(--accent);
  }
  .kids-illness-note {
    color: var(--ink-3);
    margin-top: 22px;
    font-style: italic;
  }

  /* 10. CTA — connect (centered, mirrors students CTA) */
  .kids-cta {
    text-align: center;
  }
  .kids-cta-eyebrow {
    margin-bottom: 24px;
    display: flex;
    justify-content: center;
  }
  .kids-cta-title {
    margin-bottom: 24px;
  }
  .kids-cta-lede {
    margin: 0 auto;
    max-width: 48ch;
  }
  .kids-cta-actions {
    margin-top: 32px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Mobile collapses — enhancement beyond the prototype (consistent precedent). */
  @media (max-width: 720px) {
    .kids-hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .kids-sched-grid {
      grid-template-columns: 1fr;
    }
    .kids-mission-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .kids-strip-grid {
