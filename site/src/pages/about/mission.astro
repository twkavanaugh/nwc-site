---
import Layout from "../../layouts/Layout.astro";

// Mission / Vision (/about/mission) — Direction D "Devotional".
// Translated from brand/prototype/page-mission-devotional.jsx. Quiet, reverent,
// centered narrow reading column; Newsreader serif (var(--serif)) for accents.
// React/onNav stripped; inline styles → semantic tokens + page-local classes.

const movements = [
  {
    num: "i.",
    love: "We love God",
    word: "Know",
    body: "Loving God in response to His great love for us is the great privilege and calling of every Christian — what Jesus called the greatest commandment. Because we love God, we dwell with Him daily, gather as a church to worship, and study the Bible.",
  },
  {
    num: "ii.",
    love: "We love one another",
    word: "Grow",
    body: "Knowing the love of God leads to love for the family of God—the church. Jesus said Christians validate their faith before a watching world by their love for one another. Because of this, we fellowship with one another in community, serve the needs of the church, and embody our faith at home.",
  },
  {
    num: "iii.",
    love: "We love our neighbor",
    word: "Go",
    body: "The love of God in Jesus is too good to be kept to one group or people. Because we love our neighbor, we bear witness to the gospel, steward our resources for generosity, and send church members to do gospel ministry elsewhere.",
  },
];
---

<Layout
  title="Mission & Vision · North Wake Church"
  description="North Wake Church exists to know the love of God in Jesus Christ, grow in love for one another, and go in love to reach our neighbors near and far."
>
  <!-- Breadcrumb (global .crumb pattern) -->
  <section class="crumb-sec">
    <div class="wrap">
      <div class="mono crumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span>About</span>
        <span class="sep">/</span>
        <span class="current">Mission &amp; Vision</span>
      </div>
    </div>
  </section>

  <!-- Hero statement -->
  <section class="mv-hero-sec">
    <div class="wrap-reading mv-center">
      <div class="eyebrow mv-eyebrow"><span class="dot"></span>What is the heartbeat of North Wake Church?</div>
      <p class="mv-hero-statement">
        We are a family of faith that exists to <span class="em-accent">know</span>,
        <span class="em-accent">grow</span>, and <span class="em-accent">go</span> in love.
      </p>
    </div>
  </section>

  <!-- Mission sentence -->
  <section class="mv-mission-sec">
    <div class="wrap-reading mv-center">
      <div class="mv-divider"></div>
      <p class="body mv-mission-lead">
        To know the love of God in Jesus Christ, to grow in love for one another,
        and to go in love to reach our neighbors near and far.
      </p>
      <p class="body mv-mission-sub">
        In other words, we seek to live out three great loves, fueled by the One
        Greatest Love.
      </p>
    </div>
  </section>

  <!-- Framing paragraph -->
  <section class="mv-framing-sec">
    <div class="wrap-reading mv-center">
      <p class="body mv-framing-text">
        Christian love is not mere sentiment or niceness. God's love is a strong,
        holy love that leads to deep life change. As we come to know and believe the
        love God has for us in Jesus Christ by the work of the Holy Spirit, our hearts
        will be deeply changed such that we overflow with genuine love for God and
        others. So, our ministries and values are shaped around our three great loves,
        all in response to the One Great Love of God in Jesus Christ.
      </p>
      <div class="mv-framing-cta">
        <a class="btn btn-ghost" href="/who-is-jesus">
          If this is unfamiliar, read “Who is Jesus?” <span class="arr">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Three movements -->
  <section class="mv-movements-sec">
    <div class="wrap-reading">
      <div class="mv-movements-intro">
        <div class="mv-movements-intro-text">Because God has so loved us…</div>
      </div>

      {
        movements.map((m) => (
          <div class="mv-movement">
            <div class="mv-movement-love">{m.num} {m.love}</div>
            <h2 class="mv-movement-word">{m.word}</h2>
            <p class="body mv-movement-body">{m.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Closing statement -->
  <section class="mv-closing-sec">
    <div class="wrap-reading mv-center">
      <p class="mv-closing-quote">
        “Three great loves, all in response to the One Great Love of God in Jesus Christ.”
      </p>
      <div class="mv-closing-actions">
        <a class="btn btn-primary" href="/visit">Plan a visit <span class="arr">→</span></a>
        <a class="btn btn-ghost" href="/community/grow-groups">Find community</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Shared centering for the reading-column sections */
  .mv-center {
    text-align: center;
  }

  /* Hero statement */
  .mv-hero-sec {
    padding: 104px 0 0;
  }
  .mv-eyebrow {
    display: flex;
    justify-content: center;
    margin-bottom: 40px;
  }
  .mv-hero-statement {
    font-family: var(--serif);
    font-size: clamp(28px, 4vw, 52px);
    line-height: 1.35;
    font-weight: 400;
    color: var(--ink);
    text-wrap: balance;
    margin: 0 auto;
    max-width: 20ch;
  }

  /* Mission sentence */
  .mv-mission-sec {
    padding: 64px 0;
  }
  .mv-divider {
    width: 48px;
    height: 1px;
    background: var(--line-strong);
    margin: 0 auto 40px;
  }
  .mv-mission-lead {
    font-size: 20px;
    line-height: 1.75;
    color: var(--ink-2);
    max-width: 54ch;
    margin: 0 auto;
  }
  .mv-mission-sub {
    font-size: 17px;
    line-height: 1.6;
    color: var(--ink-3);
    max-width: 46ch;
    margin: 20px auto 0;
  }

  /* Framing paragraph */
  .mv-framing-sec {
    padding: 24px 0 16px;
  }
  .mv-framing-text {
    font-size: 18px;
    line-height: 1.8;
    color: var(--ink-2);
    max-width: 58ch;
    margin: 0 auto;
  }
  .mv-framing-cta {
    margin-top: 32px;
  }

  /* Three movements */
  .mv-movements-sec {
    padding: 0 0 32px;
  }
  .mv-movements-intro {
    text-align: center;
    padding: 48px 0 8px;
  }
  .mv-movements-intro-text {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--ink);
  }
  .mv-movement {
    text-align: center;
    padding: 56px 0;
    border-top: 1px solid var(--line);
  }
  .mv-movement:last-child {
    border-bottom: 1px solid var(--line);
  }
  .mv-movement-love {
    font-family: var(--serif);
    font-style: italic;
    font-size: 22px;
    color: var(--accent);
    margin-bottom: 18px;
  }
  .mv-movement-word {
    font-family: var(--display);
    font-weight: 600;
    font-size: clamp(40px, 6vw, 72px);
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0 0 24px;
  }
  .mv-movement-body {
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-2);
    max-width: 50ch;
    margin: 0 auto;
  }

  /* Closing statement */
  .mv-closing-sec {
    padding: 80px 0 96px;
  }
  .mv-closing-quote {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(22px, 2.6vw, 32px);
    line-height: 1.5;
    color: var(--ink);
    max-width: 32ch;
    margin: 0 auto;
    text-wrap: balance;
  }
  .mv-closing-actions {
    margin-top: 40px;
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
