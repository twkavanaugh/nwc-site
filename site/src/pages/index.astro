---
import Layout from "../layouts/Layout.astro";
import { BUSINESS } from "../data/business";

// Homepage — Pass 1 of 3: Overlay hero, marquee strip, Service Times band.
// Translated from brand/prototype/page-home.jsx (HeroOverlay ~57, ServiceTimes
// ~158) + shell.jsx (Marquee) + styles.css (.marquee). React/onNav stripped;
// onNav buttons are now real <a href> per the route map.

const MARQUEE_WORDS = [
  "Sundays 9 & 11 AM",
  "Wake Forest, NC",
  "Kids welcome",
  "Coffee on us",
  "Come as you are",
];
---

<Layout
  title="North Wake Church"
  description="North Wake Church is a family of faith in Wake Forest, NC — gathering each Sunday to worship Jesus and scattering through the week to love our neighbors near and far."
>
  <!-- ===================== HERO — "Scene + People" (devotional) ===================== -->
  <!-- A) Watercolor devotional hero — the place -->
  <section class="shero">
    <div class="shero-stage">
      <div class="shero-bg" aria-label="Watercolor of downtown Wake Forest"></div>
      <!-- Cream legibility scrim over the watercolor (page-local literal exception:
           real-image scrim, not a theme color — cf. --shadow-dropdown precedent). -->
      <div class="shero-scrim"></div>

      <div class="wrap-narrow shero-content">
        <div class="eyebrow fade-up shero-eyebrow">
          <span class="dot"></span>A family of faith · Wake Forest, NC
        </div>
        <h1 class="serif fade-up shero-title" style="animation-delay: 60ms;">
          A place to <span class="em-accent">know</span>, <span class="em-accent">grow</span>, and <span class="em-accent">go</span> in love.
        </h1>
        <p class="serif fade-up shero-lede" style="animation-delay: 140ms;">
          Right here in downtown Wake Forest — gathering each Sunday to worship Jesus,
          and scattering through the week to love our neighbors near and far.
        </p>
        <div class="shero-actions fade-up" style="animation-delay: 200ms;">
          <a class="btn btn-primary" href="/visit">Plan a visit <span class="arr">→</span></a>
          <a class="btn btn-ghost" href="/sermons">Watch Sunday's sermon</a>
        </div>
      </div>
    </div>
  </section>

  <!-- B) Transition — serif line carries the eye from the place to the people -->
  <section class="shero-transition-sec">
    <div class="wrap-narrow shero-transition">
      <div class="shero-rule" aria-hidden="true"></div>
      <p class="serif shero-transition-line">
        But a church was never the streets — it's the people who fill them.
      </p>
    </div>
  </section>

  <!-- C) The people — framed 21:9 photo with a quiet caption -->
  <section class="shero-people-sec">
    <div class="wrap">
      <div class="shero-people">
        <div class="shero-people-photo" aria-label="People gathered at North Wake Church"></div>
        <!-- TODO: remove people-photo-pending marker when /home-hero.jpg is added -->
        <div class="shero-people-pending" aria-hidden="true">Photo pending</div>
        <!-- /TODO people-photo-pending -->
        <!-- Caption scrim (page-local literal exception: photo-darkening gradient). -->
        <div class="shero-people-caption">
          <div class="serif shero-people-caption-text">One family, gathered around the gospel.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== MARQUEE STRIP ===================== -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>
        {MARQUEE_WORDS.map((w) => (<><span>{w}</span><span class="sep">✦</span></>))}
      </span>
      <span>
        {MARQUEE_WORDS.map((w) => (<><span>{w}</span><span class="sep">✦</span></>))}
      </span>
    </div>
  </div>

  <!-- ===================== SERVICE TIMES BAND ===================== -->
  <section class="service">
    <div class="wrap">
      <div class="service-band">
        <div>
          <div class="mono service-eyebrow">Sundays</div>
          <div class="display-s service-time">9:00 <span class="sep-dot">·</span> 11:00 AM</div>
        </div>
        <div class="service-loc">
          <div class="mono service-eyebrow">Location</div>
          <div class="title service-addr">{BUSINESS.streetAddress} · {BUSINESS.city}, {BUSINESS.state}</div>
          <div class="small service-note">Free parking · Kids check-in opens 30 min before service</div>
        </div>
        {/* TODO: "Get directions" has no internal route; wire to a maps link once
            the address is verified. Inert for now (matches prototype's no-op). */}
        <button type="button" class="btn btn-ghost service-cta">
          Get directions <span class="arr">→</span>
        </button>
      </div>
    </div>
  </section>

  <!-- ===================== MISSION TRIAD ===================== -->
  <section class="mission">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow head-eyebrow"><span class="dot"></span>Why we exist</div>
          <h2 class="display-m mission-head">Three words shape everything we do.</h2>
        </div>
        <p class="body right">
          Our mission isn't a slogan — it's the orbit our church moves in. Sunday
          gathering, weekday community, sent into Wake Forest and beyond.
        </p>
      </div>
      <div class="mission-grid">
        {
          [
            { verb: "Know", headline: "the love of God in Jesus Christ.", body: "We orient every Sunday and every week around the gospel — that God meets us in Jesus, and that meeting changes everything.", ph: "Worship · candid" },
            { verb: "Grow", headline: "in love for one another.", body: "We don't grow in isolation. In Grow Groups, classes, and shared meals, we open Scripture, pray honestly, and bear each other's burdens.", ph: "Grow Group · home" },
            { verb: "Go", headline: "in love to reach our neighbors near and far.", body: "From Wake Forest to the nations, we send and serve — through local outreach, mercy ministry, and global missions.", ph: "Local outreach · serving" },
          ].map((it, i) => (
            <article class="mission-item">
              <div class="ph" style="aspect-ratio: 4 / 5;">
                <span class="ph-label">{it.ph}</span>
              </div>
              <div class="mission-num-row">
                <span class="mono mission-num">0{i + 1}</span>
                <span class="display-s mission-verb">{it.verb}</span>
              </div>
              <h3 class="title mission-headline">{it.headline}</h3>
              <p class="body mission-body">{it.body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== PLAN-VISIT TEASER ===================== -->
  <section class="visit">
    <div class="wrap">
      <div class="visit-grid">
        <div class="visit-aside">
          <div class="eyebrow head-eyebrow"><span class="dot"></span>Plan a visit</div>
          <h2 class="display-m visit-title">What to expect on Sunday.</h2>
          <p class="lede visit-lede">
            Walking into a new church can feel like a lot. Here's exactly what your
            first Sunday at North Wake will look like — no surprises.
          </p>
          <div class="visit-actions">
            <a class="btn btn-primary" href="/visit">I'm new — start here <span class="arr">→</span></a>
          </div>
          <div class="visit-ph">
            <div class="ph" style="aspect-ratio: 1 / 1;">
              <span class="ph-label">Welcome Walk-Up Candid</span>
            </div>
          </div>
        </div>
        <div>
          {
            [
              { k: "01", h: "Come as you are", b: "Jeans, a suit, somewhere in between — we don't dress to impress, we come to worship." },
              { k: "02", h: "Find a friendly face", b: "Grab a coffee at the Welcome Wall. Our team is there to help you find your seat (and your people)." },
              { k: "03", h: "Worship together", b: "Songs, prayer, and a sermon that takes the Bible seriously and your questions seriously, too." },
              { k: "04", h: "Kids are well cared for", b: "Safe, joyful, gospel-centered programming for birth through 5th grade in both services." },
            ].map((p) => (
              <div class="visit-point">
                <span class="mono visit-k">{p.k}</span>
                <div>
                  <h3 class="display-s visit-h">{p.h}</h3>
                  <p class="body visit-b">{p.b}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== FIND COMMUNITY ===================== -->
  <section class="community">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow head-eyebrow"><span class="dot"></span>Find community</div>
          <h2 class="display-m community-head">North Wake is a people, not a building.</h2>
        </div>
        <p class="body right">
          Sunday is a doorway, but life happens around the table. Find your people —
          a Grow Group, a class, a ministry that fits the season you're in.
        </p>
      </div>

      <div class="hairline-grid community-grid">
        {
          [
            { name: "Grow Groups", meta: "12 active groups · weekly", body: "Mid-sized groups meeting in homes across Wake Forest. Share a meal, open Scripture, pray honestly, repeat.", href: "/community/grow-groups" },
            { name: "Adult Discipleship", meta: "8-week classes · Sundays 9 AM", body: "Theology and life classes for every season — from foundations of the faith to parenting, marriage, and money.", href: "/community/adult-discipleship" },
            { name: "Students", meta: "6th–12th · Wednesdays 6:30 PM", body: "A ministry for students and families to follow Jesus together — rooted in Colossians 1: presenting everyone mature in Christ.", href: "/community/students" },
            { name: "Kids", meta: "Birth–5th · Sunday mornings", body: "A safe, joyful place where kids hear that Jesus loves them and learn to love him back. Check-in 30 min before service.", href: "/community/kids" },
            { name: "Women", meta: "Bible studies · retreats", body: "Studies in the Word, friendships across generations, and gatherings that point women to the steadfast love of Christ.", href: "/community/women" },
            { name: "Men", meta: "Breakfast · book studies", body: "Men sharpening men — meeting over coffee and Scripture to grow into faithful husbands, fathers, and friends.", href: "/community/men" },
          ].map((g) => (
            <a class="community-card" href={g.href}>
              <div class="mono community-meta">{g.meta}</div>
              <h3 class="display-s community-name">{g.name}</h3>
              <p class="body community-body">{g.body}</p>
              <div class="community-cta">
                <span class="small label">Learn more</span>
                <span class="row-arr">→</span>
              </div>
            </a>
          ))
        }
      </div>

      <div class="community-all">
        <a class="btn btn-ghost" href="/community/grow-groups">See all ministries <span class="arr">→</span></a>
      </div>
    </div>
  </section>

  <!-- ===================== LATEST SERMON ===================== -->
  <section class="latest">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow head-eyebrow"><span class="dot"></span>Now preaching</div>
          <h2 class="display-m latest-head">Sundays preached, weekly archived.</h2>
        </div>
        <p class="body right">
          We're walking through a sermon series each season. Listen along, or browse
          the full archive by speaker, series, or book.
        </p>
      </div>

      <a class="sermon-card" href="/sermons">
        <div class="sermon-art">
          <div class="mono sermon-art-tl">Series artwork</div>
          <div class="sermon-art-title">Be<br />Different</div>
          <div class="mono sermon-art-bl">Romans</div>
        </div>
        <div class="sermon-body">
          <div class="mono sermon-kicker">Current series · Spring 2026</div>
          <h3 class="display-m sermon-title">Be Different — a journey through Romans.</h3>
          <p class="body sermon-lede">
            Paul's letter to the Romans, preached week by week — the gospel that
            re-orders everything: how we relate to God, to one another, and to a
            watching world.
          </p>
          <div class="sermon-foot">
            <span class="mono sermon-listen">Listen to the latest message →</span>
            {/* Card-level link already targets /sermons; this is a styled span,
                not a nested anchor (invalid HTML). */}
            <span class="btn btn-ghost">Sermon archive</span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ===================== CARE (dark band) ===================== -->
  <section class="care">
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow head-eyebrow care-eyebrow"><span class="dot"></span>Find help</div>
          <h2 class="display-m care-title">When life is hard, you don't walk alone.</h2>
        </div>
        <p class="body right care-note">
          North Wake operates four ministries that exist to serve the wounded, the
          hungry, and the worn-out — members and neighbors alike.
        </p>
      </div>

      <div class="care-grid">
        {
          [
            { name: "Hope Counseling Center", tag: "Counseling", body: "Christ-centered, Scripture-driven biblical counseling for the church and the community.", href: "/help/hope-counseling" },
            { name: "Mercy Health Clinic", tag: "Health", body: "Free and low-cost medical care offered as a tangible expression of God's love.", href: "/help/mercy-clinic" },
            { name: "Feed Ministry", tag: "Food pantry", body: "More than groceries — meaningful conversations, prayer, and witness alongside material help.", href: "/help/feed" },
            { name: "Care Ministry", tag: "Care", body: "Meals, visits, and presence for members walking through illness, grief, and hard seasons.", href: "/help/care" },
          ].map((c) => (
            <a class="care-card" href={c.href}>
              <span class="mono care-tag">{c.tag}</span>
              <h3 class="title care-name">{c.name}</h3>
              <p class="small care-body">{c.body}</p>
              <div class="care-cta">
                <span>Learn more</span>
                <span>→</span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===================== EVENTS + WHO IS JESUS ===================== -->
  <section class="events">
    <div class="wrap">
      <div class="events-grid">
        <div>
          <div class="eyebrow head-eyebrow"><span class="dot"></span>What's next</div>
          <h2 class="display-m events-title">Upcoming.</h2>
          <div class="events-list">
            {
              [
                { d: "May", n: "31", title: "Ministry Intensive Internship · 2026–27", time: "Applications open · Info session", href: "/events" },
                { d: "May", n: "03", title: "Membership Class · Spring Cohort", time: "Sundays · 9:00 AM", href: "/about/membership" },
                { d: "Oct", n: "24", title: "Women's Day · Women Encouraging Women", time: "8:30 AM – 3:30 PM", href: "/events" },
                { d: "Jun", n: "01", title: "Baptism Sunday", time: "Both services", href: "/events" },
              ].map((e) => (
                <a class="row-link event-row" href={e.href}>
                  <div class="event-left">
                    <div class="event-date">
                      <div class="mono event-month">{e.d}</div>
                      <div class="display-s event-day">{e.n}</div>
                    </div>
                    <div>
                      <div class="title event-name">{e.title}</div>
                      <div class="small">{e.time}</div>
                    </div>
                  </div>
                  <span class="row-arr event-arr">→</span>
                </a>
              ))
            }
          </div>
          <div class="events-actions">
            <a class="btn btn-ghost" href="/events">Full calendar <span class="arr">→</span></a>
          </div>
        </div>

        <aside class="jesus-aside">
          <div class="eyebrow head-eyebrow jesus-eyebrow"><span class="dot"></span>For the seeker</div>
          <h3 class="display-m jesus-title">Who is Jesus?</h3>
          <p class="body jesus-body">
            Maybe you're not a Christian. Maybe you used to be. Maybe you've never
            thought about it seriously. This is a page written for honest questions —
            no jargon, no pressure.
          </p>
          <div class="jesus-actions">
            <a class="btn jesus-btn" href="/who-is-jesus">Read it <span class="arr">→</span></a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ============ HERO — "Scene + People" (devotional) ============ */
  /* A) Watercolor devotional hero */
  .shero {
    padding: 0;
  }
  .shero-stage {
    position: relative;
    width: 100%;
    min-height: 76vh;
    display: flex;
    overflow: hidden;
  }
  .shero-bg {
    position: absolute;
    inset: 0;
    background-image: url("/wake-forest-bcg.png");
    background-size: cover;
    background-position: center 60%;
    /* DOCUMENTED page-local literal: watercolor-paper fallback behind the image,
       only visible if it fails to load. Nearest raw token is --raw-sand-50
       (#f6f3ed) but it's tonally distinct (cooler) and serves a different role
       (page bg); the doc's #f3ecdf matches the watercolor's paper tone. */
    background-color: #f3ecdf;
  }
  /* DOCUMENTED page-local literal exception: cream legibility scrim over the
     watercolor (real-image scrim, not a theme color — cf. --shadow-dropdown). */
  .shero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(246, 243, 237, 0.72) 0%,
      rgba(246, 243, 237, 0.28) 40%,
      rgba(246, 243, 237, 0.92) 100%
    );
  }
  .shero-content {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    width: 100%;
    padding-top: 72px;
    padding-bottom: 72px;
  }
  .shero-eyebrow {
    margin-bottom: 40px;
    display: flex;
    justify-content: center;
  }
  .shero-title {
    font-weight: 400;
    font-size: clamp(46px, 7.5vw, 120px);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0;
    max-width: 16ch;
    text-wrap: balance;
  }
  .shero-lede {
    font-weight: 400;
    font-size: clamp(19px, 2vw, 25px);
    line-height: 1.6;
    color: var(--ink-2);
    margin: 32px auto 0;
    max-width: 40ch;
  }
  .shero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 40px;
    flex-wrap: wrap;
  }

  /* B) Transition line */
  .shero-transition-sec {
    padding-top: 72px;
    padding-bottom: 0;
  }
  .shero-transition {
    text-align: center;
  }
  .shero-rule {
    width: 1px;
    height: 48px;
    background: var(--line-strong);
    margin: 0 auto 28px;
  }
  .shero-transition-line {
    font-style: italic;
    font-weight: 400;
    font-size: clamp(24px, 3vw, 38px);
    line-height: 1.35;
    letter-spacing: -0.015em;
    color: var(--ink);
    max-width: 24ch;
    margin: 0 auto;
    text-wrap: balance;
  }

  /* C) People photo */
  .shero-people-sec {
    padding-top: 56px;
    padding-bottom: 0;
  }
  .shero-people {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  .shero-people-photo {
    aspect-ratio: 21 / 9;
    width: 100%;
    /* TODO: real Sunday-gathering photo dropped into site/public/home-hero.jpg
       later; --bg-2 keeps the frame legible until then. */
    background-image: url("/home-hero.jpg");
    background-size: cover;
    background-position: center 35%;
    background-color: var(--bg-2);
  }
  /* Quiet placeholder marker (over the light --bg-2 fallback; token colors).
     Deleted with the TODO block in the markup once the photo lands. */
  .shero-people-pending {
    position: absolute;
    top: 18px;
    right: 22px;
    z-index: 2;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--ink-3);
    background: color-mix(in srgb, var(--bg) 90%, transparent);
    border: 1px solid var(--line);
    padding: 5px 10px;
    border-radius: var(--radius-sm);
  }
  /* DOCUMENTED page-local literal exception: photo-darkening caption gradient +
     white-on-photo caption text (not theme colors). */
  .shero-people-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 40px 40px 28px;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.55) 100%);
  }
  .shero-people-caption-text {
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 24px);
    color: rgba(255, 255, 255, 0.95);
    max-width: 30ch;
  }
  @media (max-width: 720px) {
    .shero-people-caption {
      padding: 24px 22px 20px;
    }
  }

  /* --------------------------------- MARQUEE -------------------------------- */
  .marquee {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
    overflow: hidden;
    display: flex;
    gap: 48px;
    white-space: nowrap;
    font-family: var(--display);
    font-size: clamp(20px, 2.4vw, 32px);
    font-weight: 600;
    letter-spacing: -0.02em;
  }
  .marquee-track {
    display: inline-flex;
    gap: 48px;
    animation: marquee 50s linear infinite;
  }
  .marquee-track > span {
    display: inline-flex;
    gap: 48px;
  }
  .marquee-track .sep {
    color: var(--accent);
  }
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  /* Accessibility improvement over the prototype: respect reduced-motion. */
  @media (prefers-reduced-motion: reduce) {
    .marquee-track {
      animation: none;
    }
  }

  /* ------------------------------ SERVICE TIMES ----------------------------- */
  .service {
    padding: 80px 0;
  }
  .service-band {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 56px;
    padding: 32px 0;
    border-top: 1px solid var(--line-strong);
    border-bottom: 1px solid var(--line-strong);
  }
  .service-eyebrow {
    margin-bottom: 6px;
  }
  .service-time {
    font-weight: 500;
  }
  .service-time .sep-dot {
    color: var(--ink-3);
  }
  .service-loc {
    border-left: 1px solid var(--line);
    padding-left: 56px;
  }
  .service-addr {
    font-weight: 500;
  }
  .service-note {
    margin-top: 4px;
  }

  @media (max-width: 720px) {
    .service-band {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .service-loc {
      border-left: 0;
      padding-left: 0;
    }
  }

  /* ----------------------- SHARED: eyebrow dot + placeholder ---------------- */
  /* Section eyebrow + its accent dot (global .eyebrow .dot only sets color). */
  .head-eyebrow {
    margin-bottom: 18px;
    color: var(--ink-3);
  }
  .head-eyebrow .dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    margin-right: 10px;
    transform: translateY(-2px);
  }

  /* .ph / .ph-label / .ph-dark moved to global.css (shared across pages). */

  /* ------------------------------ MISSION TRIAD ---------------------------- */
  .mission-head {
    max-width: 14ch;
  }
  .mission .right {
    color: var(--ink-2);
  }
  .mission-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .mission-item {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .mission-num-row {
    display: flex;
    align-items: baseline;
    gap: 14px;
  }
  .mission-num {
    color: var(--accent);
  }
  .mission-verb {
    color: var(--accent);
    font-weight: 600;
  }
  .mission-headline {
    max-width: 20ch;
    font-weight: 500;
  }
  .mission-body {
    margin: 0;
    max-width: 34ch;
    color: var(--ink-2);
  }

  /* --------------------------- PLAN-VISIT TEASER --------------------------- */
  .visit-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
