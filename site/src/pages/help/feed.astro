---
import Layout from "../../layouts/Layout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";

// Feed Ministry page (/help/feed). Translated from brand/prototype/page-feed.jsx.
// SECTION-GATED — this pass builds ONLY: 1) Breadcrumb, 2) Hero, 3) Two convictions.
// Sections 4–7 (how we serve [dark band], 3 paths, hours & location, CTA) NOT built yet.

const convictions = [
  {
    n: "01",
    h: "God's love extends to every kind of need.",
    b: "Physical hunger, emotional weight, spiritual longing — none of it falls outside the reach of Christ. We try to meet people where each of those needs sits.",
  },
  {
    n: "02",
    h: "God is present among the poor and needy.",
    b: "We don't bring God to the pantry — we meet him there. Scripture has been pointing us toward this for a long time, and our experience confirms it week after week.",
  },
];
---

<Layout
  title="Feed Ministry · North Wake Church"
  description="Feed is a food pantry ministry at North Wake Church — more than groceries: community, prayer, and presence, believing God's love extends to physical, emotional, and spiritual needs."
>
  <!-- 1. Breadcrumb ("Help" has no page → non-clickable placeholder chip) -->
  <Breadcrumb
    trail={[{ label: "Home", href: "/" }, { label: "Help" }, { label: "Feed Ministry" }]}
  />

  <!-- 2. Hero (mirrors the students/kids hero shape) -->
  <section class="feed-hero">
    <div class="wrap">
      <div class="feed-hero-grid">
        <div>
          <div class="eyebrow feed-hero-eyebrow"><span class="dot"></span>Feed Ministry · Food pantry</div>
          <h1 class="display-l feed-h1">
            More than groceries — <span class="feed-accent">community, prayer,</span> presence.
          </h1>
          <p class="lede feed-lede">
            Feed is a food pantry ministry at North Wake Church. We come together to
            find community and connection with God — believing his love extends to
            physical, emotional, and spiritual needs.
          </p>
          <div class="feed-hero-actions">
            {/* TODO: no clear route in the prototype — inert placeholders; wire once
                targets are confirmed (e.g. a visit/volunteer destination). */}
            <button type="button" class="btn btn-primary">Stop by Feed <span class="arr">→</span></button>
            <button type="button" class="btn btn-ghost">Volunteer</button>
          </div>
        </div>
        <div class="ph" style="aspect-ratio: 4 / 5;">
          <span class="ph-label">Feed · candid</span>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Two convictions (page-local bordered cards — NOT .kids-card; values diverge) -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow feed-eyebrow"><span class="dot"></span>What is Feed</div>
          <h2 class="display-m feed-convictions-title">Two convictions shape everything.</h2>
        </div>
        <p class="body right">
          Poverty is much more than a monetary issue, so we don't just hand out
          toiletries and groceries. We engage in real conversation, real prayer, and
          real witness.
        </p>
      </div>

      <div class="feed-convictions-grid">
        {
          convictions.map((c) => (
            <div class="feed-card">
              <div class="mono feed-card-label">{c.n} · Conviction</div>
              <h3 class="display-s feed-card-title">{c.h}</h3>
              <p class="feed-card-body">{c.b}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 4. How we serve (DARK band — inverse tokens, no raw white literals) -->
  <section class="feed-serve">
    <div class="wrap">
      <div class="eyebrow feed-serve-eyebrow"><span class="dot"></span>How we serve</div>
      <h2 class="display-m feed-serve-title">
        Conversation, prayer, witness — alongside the groceries.
      </h2>
      <p class="feed-serve-body">
        We get to know people by engaging in meaningful conversations, praying for
        each person, and witnessing to the gospel. We believe and experience that God
        is at work in this world and in the lives of those in need.
      </p>
    </div>
  </section>

  <!-- 5. How to engage — 3 paths (hairline-gap grid — 4th occurrence; page-local) -->
  <section>
    <div class="wrap">
      <div class="section-head">
        <div>
          <div class="eyebrow feed-eyebrow"><span class="dot"></span>How to engage</div>
          <h2 class="display-m">Three ways in.</h2>
        </div>
      </div>

      <div class="feed-paths">
        <!-- Path 1: Receive -->
        <div class="feed-path">
          <div class="mono feed-path-label">01 · Receive</div>
          <h3 class="title feed-path-title">Stop by — we want to meet you.</h3>
          <p class="feed-path-body">
            No matter who you are or what situation you're in, we're here to help with
            any needs you have — food insecurity, basic necessities, or connecting you
            to other resources.
          </p>
          <p class="feed-path-body feed-path-body--strong">
            Just stop by whenever we're open. We'd love to get to know you.
          </p>
        </div>

        <!-- Path 2: Donate -->
        <div class="feed-path">
          <div class="mono feed-path-label">02 · Donate</div>
          <h3 class="title feed-path-title">Drop groceries in the teal box.</h3>
          <p class="feed-path-body">
            Grab some extra groceries when you go shopping and drop them off at the
            teal box in the church lobby. The simplest way to support Feed every week.
          </p>
          <div class="feed-donate-note">
            {/* Documented exception: the donation box is physically teal — uses
                --raw-teal (the one sanctioned raw token, per design-tokens.md). */}
            <span class="feed-teal-swatch" aria-hidden="true"></span>
            Look for the teal box · church lobby
          </div>
        </div>

        <!-- Path 3: Volunteer -->
        <div class="feed-path">
          <div class="mono feed-path-label">03 · Volunteer</div>
          <h3 class="title feed-path-title">Serve alongside the team.</h3>
          <p class="feed-path-body">
            Interested in joining the Feed team? Reach out to either of our
            coordinators — they'll walk you through how to get started.
          </p>
          {/* TODO: coordinator contacts are UNVERIFIED — rendered inert, NO mailto.
              Prototype had tylerp@northwake.com and a PERSONAL Gmail
              (mccaberose6@gmail.com). Do NOT publish the personal Gmail; church must
              confirm/replace both before any live link. */}
          <div class="feed-volunteer-list">
            <div class="feed-volunteer-row">
              <span><span class="feed-volunteer-name">Tyler · </span>email pending verification</span>
              <span class="feed-volunteer-arr" aria-hidden="true">→</span>
            </div>
            <div class="feed-volunteer-row">
              <span><span class="feed-volunteer-name">Rose · </span>email pending verification</span>
              <span class="feed-volunteer-arr" aria-hidden="true">→</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .feed-hero {
    padding: 56px 0 0;
  }
  .feed-hero-grid {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
    align-items: end;
  }
  .feed-hero-eyebrow {
    margin-bottom: 28px;
  }
  .feed-h1 {
    max-width: 16ch;
  }
  /* Non-italic accent span (no global accent-color utility; .em-accent adds italic). */
  .feed-accent {
    color: var(--accent);
  }
  .feed-lede {
    margin-top: 28px;
  }
  .feed-hero-actions {
    display: flex;
    gap: 12px;
    margin-top: 32px;
    flex-wrap: wrap;
  }

  /* Two convictions — page-local bordered cards (diverge from .kids-card:
     padding 36px 36px 32px, border-radius, bg-2 fill). */
  .feed-eyebrow {
    margin-bottom: 18px;
  }
  .feed-convictions-title {
    max-width: 14ch;
  }
  .feed-convictions-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }
  .feed-card {
    padding: 36px 36px 32px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-card);
    background: var(--bg-2);
  }
  .feed-card-label {
    color: var(--accent);
    margin-bottom: 16px;
  }
  .feed-card-title {
    font-weight: 500;
    margin-bottom: 16px;
    max-width: 20ch;
  }
  .feed-card-body {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
  }

  /* 4. How we serve — DARK band, inverse semantic tokens only (no raw white). */
  .feed-serve {
    background: var(--bg-inverse);
    color: var(--ink-on-inverse);
  }
  .feed-serve-eyebrow {
    margin-bottom: 18px;
    color: var(--ink-on-inverse-2);
  }
  .feed-serve-title {
    color: var(--ink-on-inverse);
    max-width: 20ch;
    margin-bottom: 28px;
  }
  .feed-serve-body {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-on-inverse-2);
    max-width: 60ch;
    margin: 0;
  }

  /* 5. How to engage — 3 paths.
     Hairline-gap card grid — SAME idiom as homepage community / students rhythms /
     kids schedule. 4th occurrence and the genuinely-ripe extraction candidate;
     kept page-local this gate (extraction is a separate pass). */
  .feed-paths {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }
  .feed-path {
    background: var(--bg);
    padding: 36px 32px 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    min-height: 320px;
  }
  .feed-path-label {
    color: var(--accent);
  }
  .feed-path-title {
    font-weight: 500;
    font-size: 24px;
    letter-spacing: -0.015em;
  }
  .feed-path-body {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-2);
  }
  .feed-path-body--strong {
    font-weight: 500;
  }

  /* Donate note + teal swatch. The swatch fill uses --raw-teal — the one
     sanctioned raw-token use (a real-world object color; design-tokens.md:
     "Feed page donation-box swatch ONLY — keep page-local"). */
  .feed-donate-note {
    margin-top: auto;
    padding-top: 14px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--ink-3);
  }
  .feed-teal-swatch {
    width: 14px;
    height: 14px;
    border-radius: var(--radius-sm);
    background: var(--raw-teal);
    border: 1px solid var(--line);
    flex: none;
  }

  /* Volunteer contacts — inert placeholders (no mailto; unverified contacts). */
  .feed-volunteer-list {
    margin-top: auto;
    padding-top: 14px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .feed-volunteer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-card);
    font-size: 14px;
  }
  .feed-volunteer-name {
    color: var(--ink-3);
  }
  .feed-volunteer-arr {
    color: var(--accent);
  }

  /* Mobile collapses — enhancement beyond the prototype (consistent precedent). */
  @media (max-width: 720px) {
    .feed-hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .feed-convictions-grid {
      grid-template-columns: 1fr;
    }
    .feed-paths {
      grid-template-columns: 1fr;
    }
  }
</style>
