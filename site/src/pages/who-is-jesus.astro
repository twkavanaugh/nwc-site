---
import Layout from "../layouts/Layout.astro";

// Who is Jesus? (/who-is-jesus) — Direction A "Literary Essay".
// Translated from brand/prototype/page-who-is-jesus.html. Warm, serif-led
// long-form reading column. Consumes shared globals: .serif, .em-accent,
// .pull-quote, .wrap-reading, .crumb*, .eyebrow/.dot, .btn-accent, inverse
// tokens. Per-element scale/measure stays page-local. Zero JS.

const claims = [
  { n: "01", q: 'Who did He claim to be?' },
  { n: "02", q: 'Was He the "Son of God"?' },
  { n: "03", q: 'Did He bear our sins?' },
  { n: "04", q: 'Did He rise from the dead?' },
];

const resources = [
  { n: "01", title: '"The Reason for God"', author: "by Tim Keller" },
  { n: "02", title: '"3-2-1: The Story of God, the World, and You"', author: "by Glen Scrivener" },
];
---

<Layout
  title="Who is Jesus? · North Wake Church"
  description="An invitation to explore who Jesus is — for the curious, the struggling, and the skeptical. You and your questions are welcome at North Wake Church."
>
  <!-- Breadcrumb (global .crumb pattern) -->
  <section class="crumb-sec">
    <div class="wrap">
      <div class="mono crumb">
        <a href="/">Home</a>
        <span class="sep">/</span>
        <span class="current">Who is Jesus?</span>
      </div>
    </div>
  </section>

  <!-- Hero -->
  <section class="wij-hero">
    <div class="wrap-reading">
      <div class="eyebrow wij-eyebrow"><span class="dot"></span>An invitation</div>
      <h1 class="serif wij-h1">Who is <span class="em-accent">Jesus</span>?</h1>
      <p class="serif wij-hero-lede">
        If you're curious, struggling, or even skeptical — you're in the right
        place. You are welcome here, because you and your questions matter.
      </p>
    </div>
  </section>

  <!-- Big questions, as flowing prose list -->
  <section>
    <div class="wrap-reading">
      <div class="eyebrow wij-eyebrow"><span class="dot"></span>The questions we're all asking</div>
      <div class="serif wij-questions">
        What is the point of it all? <span class="wij-sep">·</span> Why do I matter?
        <span class="wij-sep">·</span> What is true love? <span class="wij-sep">·</span>
        Why is there so much injustice? <span class="wij-sep">·</span> Why do we
        struggle to be genuinely unselfish? <span class="wij-sep">·</span> Is there
        such a thing as a happy ending? <span class="wij-sep">·</span>
        <span class="em-accent">What is the good life?</span>
      </div>
    </div>
  </section>

  <!-- The claim -->
  <section>
    <div class="wrap-reading">
      <div class="wij-claim-rule"></div>
      <p class="serif wij-claim">
        And while we still have questions, we believe the most important questions
        <span class="em-accent">(and answers!)</span> hinge around Jesus Christ.
      </p>
      <p class="body wij-claim-sub">The gospel keeps drawing us back to four:</p>
      <ol class="serif wij-claims-list">
        {
          claims.map((c) => (
            <li class="wij-claim-item">
              <span class="mono wij-claim-num">{c.n}</span>
              <span>{c.q}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Good news -->
  <section>
    <div class="wrap-reading">
      <div class="eyebrow wij-eyebrow--tight"><span class="dot"></span>The good news</div>
      <p class="serif wij-goodnews">
        The good news of the Bible is that even though we have all turned away from
        God — and even replaced Him in various ways — <span class="em-accent">He came after us.</span>
      </p>
      <p class="body wij-goodnews-body">
        In the person of Jesus Christ, we believe the Son of God<sup class="wij-sup">*</sup>
        stepped into our world to live among us, suffer like us, fulfill the longings
        of our story, display God's love, satisfy God's justice, and bring us back to
        God — accomplishing our salvation in His life, death, and resurrection. He
        alone is the hope of the world and the hope of our story.
      </p>
    </div>
  </section>

  <!-- Trinity footnote -->
  <section class="wij-footnote">
    <div class="wrap-reading">
      <div class="pull-quote wij-footnote-quote">
        <div class="mono wij-footnote-label">* On the Son of God</div>
        <p class="body serif wij-footnote-text">
          When we say Jesus Christ is the Son of God, we mean that He has always
          existed as a member of the eternal community of the Triune God — Father,
          Son, and Holy Spirit. This is a mysterious and yet beautiful truth. If God
          has always existed in a Triune community, He has always been love, for He
          always had an object of love. Thus, the invitation to become a Christian is
          an invitation to enter the life and love of God, much like a dance that
          began before time itself.
        </p>
      </div>
    </div>
  </section>

  <!-- Resources -->
  <section>
    <div class="wrap-reading">
      <div class="eyebrow wij-eyebrow--tight"><span class="dot"></span>Further reading</div>
      <p class="serif wij-resources-lead">
        Feel free to contact us to set up a meeting or simply ask a question. And if
        you'd like to do some further reading on why Christianity makes sense, we'd
        recommend:
      </p>
      <div class="wij-resources">
        {
          resources.map((r) => (
            <div class="wij-resource-row">
              <span class="mono wij-resource-num">{r.n}</span>
              <span class="serif wij-resource-title">{r.title} <span class="wij-resource-author">{r.author}</span></span>
              <span class="row-arr wij-resource-arr">→</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Prayer (dark band — inverse tokens) -->
  <section class="wij-prayer">
    <div class="wrap-reading">
      <div class="eyebrow wij-prayer-eyebrow"><span class="dot"></span>If you are desiring faith</div>
      <h2 class="serif wij-prayer-h2">A prayer you might pray.</h2>
      <blockquote class="serif wij-prayer-quote">
        "Lord Jesus, I admit that I am weaker and more sinful than I ever dared admit,
        but through you I am more loved and accepted than I ever dared hope. I thank
        you for paying the debt on the cross, taking what I deserved in order to offer
        me complete forgiveness. Knowing that you have been raised from the dead, I
        wish to turn from my sins and receive you as my Savior and Lord."
      </blockquote>
      <div class="serif wij-amen">Amen.</div>
      <div class="wij-prayer-foot">
        <p class="body wij-prayer-foot-text">
          If you prayed something like this — or you'd just like to talk — we'd love
          to hear from you.
        </p>
        {/* TODO: placeholder — needs a real contact target (form/email). */}
        <button type="button" class="btn btn-accent">Tell us <span class="arr">→</span></button>
      </div>
    </div>
  </section>

  <!-- Closing -->
  <section>
    <div class="wrap-reading wij-closing">
      <p class="serif wij-closing-quote">
        You don't have to have it figured out to start the conversation.
      </p>
      <div class="wij-closing-cta">
        {/* TODO: placeholder — needs a real contact target (form/email). */}
        <button type="button" class="btn btn-primary">Coffee or tea, on us <span class="arr">→</span></button>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero */
  .wij-hero {
    padding: 88px 0 0;
  }
  .wij-eyebrow {
    margin-bottom: 36px;
  }
  .wij-eyebrow--tight {
    margin-bottom: 28px;
  }
  .wij-h1 {
    font-weight: 400;
    font-size: clamp(56px, 9vw, 140px);
    line-height: 0.98;
    letter-spacing: -0.02em;
    margin: 0 0 40px;
  }
  .wij-hero-lede {
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.5;
    font-weight: 300;
    color: var(--ink-2);
    max-width: 34ch;
    margin: 0;
  }

  /* Big questions */
  .wij-questions {
    font-size: clamp(26px, 3.4vw, 40px);
    line-height: 1.45;
    font-weight: 300;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .wij-sep {
    color: var(--ink-4);
  }

  /* The claim */
  .wij-claim-rule {
    height: 1px;
    background: var(--line-strong);
    margin-bottom: 48px;
  }
  .wij-claim {
    font-size: clamp(28px, 3.8vw, 48px);
    line-height: 1.3;
    font-weight: 400;
    letter-spacing: -0.015em;
    color: var(--ink);
    max-width: 26ch;
    margin: 0 0 28px;
    text-wrap: balance;
  }
  .wij-claim-sub {
    font-size: 18px;
    line-height: 1.7;
    color: var(--ink-2);
    max-width: 54ch;
    margin: 0 0 40px;
  }
  .wij-claims-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
  }
  .wij-claim-item {
    font-size: clamp(24px, 3vw, 34px);
    line-height: 1.3;
    font-weight: 400;
    color: var(--ink);
    padding: 24px 0;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 28px;
    align-items: baseline;
  }
  .wij-claim-item:last-child {
    border-bottom: 1px solid var(--line);
  }
  .wij-claim-num {
    color: var(--accent);
    font-size: 12px;
  }

  /* Good news */
  .wij-goodnews {
    font-size: clamp(24px, 3vw, 36px);
    line-height: 1.4;
    font-weight: 300;
    color: var(--ink);
    max-width: 40ch;
    margin: 0 0 32px;
    text-wrap: pretty;
  }
  .wij-goodnews-body {
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink-2);
    max-width: 58ch;
    margin: 0 0 20px;
  }
  .wij-sup {
    color: var(--accent);
    font-size: 0.7em;
    margin-left: 2px;
  }

  /* Trinity footnote — global .pull-quote + per-use measure */
  .wij-footnote {
    padding-top: 48px;
  }
  .wij-footnote-quote {
    max-width: 62ch;
  }
  .wij-footnote-label {
    color: var(--accent);
    margin-bottom: 12px;
  }
  .wij-footnote-text {
    font-size: 18px;
    line-height: 1.75;
    color: var(--ink-2);
    margin: 0;
    font-weight: 300;
  }

  /* Resources */
  .wij-resources-lead {
    font-size: clamp(22px, 2.6vw, 30px);
    line-height: 1.4;
    font-weight: 300;
    color: var(--ink);
    max-width: 38ch;
    margin: 0 0 40px;
  }
  .wij-resources {
    border-top: 1px solid var(--line);
  }
  .wij-resource-row {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 28px;
    align-items: baseline;
    padding: 26px 0;
    border-bottom: 1px solid var(--line);
  }
  .wij-resource-num {
    color: var(--accent);
  }
  .wij-resource-title {
    font-size: clamp(22px, 2.6vw, 30px);
    color: var(--ink);
  }
  .wij-resource-author {
    color: var(--ink-3);
    font-style: italic;
  }
  .wij-resource-arr {
    color: var(--accent);
  }

  /* Prayer (dark band) — inverse semantic tokens, no raw white literals */
  .wij-prayer {
    background: var(--bg-inverse);
    color: var(--ink-on-inverse);
    margin-top: 96px;
    padding: 96px 0;
  }
  .wij-prayer-eyebrow {
    margin-bottom: 28px;
    color: var(--ink-on-inverse-2);
  }
  .wij-prayer-h2 {
    font-weight: 400;
    font-size: clamp(34px, 5vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink-on-inverse);
    margin: 0 0 40px;
    max-width: 16ch;
  }
  .wij-prayer-quote {
    margin: 0;
    font-size: clamp(22px, 2.8vw, 32px);
    line-height: 1.5;
    font-weight: 300;
    font-style: italic;
    color: var(--ink-on-inverse);
    max-width: 40ch;
    text-wrap: pretty;
  }
  .wij-amen {
    margin-top: 24px;
    font-size: 28px;
    font-style: italic;
    color: var(--accent);
  }
  .wij-prayer-foot {
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--line-on-inverse);
    display: flex;
    gap: 24px;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
  }
  .wij-prayer-foot-text {
    margin: 0;
    color: var(--ink-on-inverse-2);
    max-width: 46ch;
  }

  /* Closing */
  .wij-closing {
    text-align: center;
  }
  .wij-closing-quote {
    font-size: clamp(28px, 3.6vw, 46px);
    line-height: 1.3;
    font-weight: 400;
    font-style: italic;
    color: var(--ink);
    max-width: 24ch;
    margin: 0 auto;
    text-wrap: balance;
  }
  .wij-closing-cta {
    margin-top: 36px;
  }
</style>
