---
// Top navigation chrome — full-width MEGA-MENU variant.
// Each group trigger opens a single full-bleed .mega panel anchored to .nav
// (columns of items + a featured rail). Static, zero-JS: panels open on
// :hover / :focus-within only; active state is computed at build time from
// Astro.url.pathname. Brand mark, direct links, and CTAs preserved from the
// prior nav. All CSS scoped here; consumes only global tokens + .btn*.

const pathname = Astro.url.pathname;

// Normalize trailing slash so "/visit/" and "/visit" both match.
const norm = (p: string) => (p !== "/" && p.endsWith("/") ? p.slice(0, -1) : p);
const here = norm(pathname);
const isActive = (href: string) => norm(href) === here;

type MegaItem = { label: string; href?: string; desc: string };
type MegaColumn = { heading: string; items: MegaItem[] };
type MegaGroup = {
  label: string;
  columns: MegaColumn[];
  featured: { kicker: string; title: string; body: string; ctaLabel: string; ctaHref: string };
};

// UNVERIFIED COPY — descriptions + featured rails are placeholders, confirm with church before launch.
// Items WITHOUT an href are unbuilt routes → rendered dimmed/non-clickable, no arrow.
const GROUPS: MegaGroup[] = [
  {
    label: "About",
    columns: [
      {
        heading: "Who We Are",
        items: [
          { label: "Our Beliefs", href: "/about/beliefs", desc: "What we hold to and why." },
          { label: "Mission & Vision", href: "/about/mission", desc: "Who we are and where we're going." },
        ],
      },
      {
        heading: "Get Involved",
        items: [
          { label: "Leadership", desc: "The team who shepherds North Wake." },
          { label: "Membership", href: "/about/membership", desc: "Make North Wake your church home." },
        ],
      },
    ],
    featured: {
      kicker: "New here?",
      title: "Start with Jesus.",
      body: "Curious, questioning, or skeptical — here's a place to begin.",
      ctaLabel: "Who is Jesus?",
      ctaHref: "/who-is-jesus",
    },
  },
  {
    label: "Mission",
    columns: [
      {
        heading: "Reach",
        items: [
          { label: "International Missions", desc: "The gospel to the nations." },
          { label: "Church Planting", desc: "New churches, near and far." },
          { label: "Local Outreach", desc: "Loving Wake Forest in word and deed." },
        ],
      },
      {
        heading: "Equip & Serve",
        items: [
          { label: "Ministry Training", desc: "Equipping the saints for the work." },
          { label: "Serve the Church", desc: "Find your place to give and grow." },
        ],
      },
    ],
    featured: {
      kicker: "Go in love",
      title: "Be sent.",
      body: "From Wake Forest to the nations — find your place in the mission.",
      ctaLabel: "Get involved",
      ctaHref: "/community/grow-groups",
    },
  },
  {
    label: "Help",
    columns: [
      {
        heading: "Counseling & Care",
        items: [
          { label: "Hope Counseling", href: "/help/hope-counseling", desc: "Biblical counseling for hard seasons." },
          { label: "Care Ministry", desc: "Practical help when life is heavy." },
        ],
      },
      {
        heading: "Health & Provision",
        items: [
          { label: "Mercy Health Clinic", desc: "Care for the uninsured in our community." },
          { label: "Feed Ministry", href: "/help/feed", desc: "Groceries and dignity for neighbors in need." },
        ],
      },
    ],
    featured: {
      kicker: "Need help now?",
      title: "You don't walk alone.",
      body: "Reach our care team and someone will follow up personally.",
      ctaLabel: "Talk to someone",
      ctaHref: "/help/hope-counseling",
    },
  },
  {
    label: "Community",
    columns: [
      {
        heading: "Groups & Classes",
        items: [
          { label: "Grow Groups", href: "/community/grow-groups", desc: "Weekly community in homes across Wake Forest." },
          { label: "Adult Discipleship", desc: "Sunday classes for every season of faith." },
        ],
      },
      {
        heading: "Next Generation",
        items: [
          { label: "Kids", href: "/community/kids", desc: "Birth–5th grade, every Sunday." },
          { label: "Students", href: "/community/students", desc: "6th–12th grade, midweek & Sundays." },
          { label: "LILY Moms", desc: "Encouragement for moms of little ones." },
        ],
      },
      {
        heading: "Men, Women & Life Stage",
        items: [
          { label: "Women", desc: "Studies, retreats, friendship." },
          { label: "Men", desc: "Breakfasts and book studies." },
          { label: "Young Adults", desc: "20s & 30s doing life together." },
          { label: "Mature Adults", href: "/community/mature-adults", desc: "Fellowship, faith, and fun." },
        ],
      },
    ],
    featured: {
      kicker: "New here?",
      title: "Find your people.",
      body: "Tell us your season of life and we'll match you to a group.",
      ctaLabel: "Get connected",
      ctaHref: "/community/grow-groups",
    },
  },
  {
    label: "Resources",
    columns: [
      {
        heading: "Watch & Read",
        items: [
          // Sermons page is NOT built yet → dimmed; the featured rail routes to /events instead.
          { label: "Sermons", desc: "Catch up on the latest series." },
          { label: "Blog", href: "/blog", desc: "Writing from our pastors and team." },
        ],
      },
      {
        heading: "Stay Connected",
        items: [
          { label: "Events", href: "/events", desc: "What's coming up at North Wake." },
          { label: "Other Resources", desc: "Reading, links, and downloads." },
        ],
      },
    ],
    featured: {
      kicker: "This Sunday",
      title: "Catch the latest.",
      body: "Miss a week? Watch the most recent sermon any time.",
      ctaLabel: "Watch now",
      ctaHref: "/events", // /sermons not built yet → route to /events for now
    },
  },
];

const groupActive = (g: MegaGroup) =>
  g.columns.some((col) => col.items.some((it) => it.href && isActive(it.href)));

const GIVE_HREF = "https://onrealm.org/NorthWake/-/form/give/now";
---

<nav class="nav">
  <div class="nav-inner">
    {/* TODO: replace CSS .brand-mark + text wordmark with a real logo asset
        (assets/nw-mark.png) once it exists — see prototype shell.jsx. */}
    <a class="brand" href="/" aria-label="North Wake Church — home">
      <span class="brand-mark" aria-hidden="true"></span>
      <span class="brand-name">North <span class="accent">Wake</span></span>
    </a>

    <div class="nav-links">
      <a class={`nav-link${isActive("/") ? " active" : ""}`} href="/">Home</a>

      {
        GROUPS.map((g) => (
          <div class="nav-item">
            <button
              type="button"
              class={`nav-link nav-trigger${groupActive(g) ? " active" : ""}`}
              aria-haspopup="true"
            >
              {g.label}
              <span class="caret" aria-hidden="true"></span>
            </button>

            <div class="mega" role="menu">
              <div class={`mega-inner cols-${g.columns.length}`}>
                {g.columns.map((col) => (
                  <div class="mega-col">
                    <div class="mega-heading">{col.heading}</div>
                    {col.items.map((it) =>
                      it.href ? (
                        <a
                          class={`mega-item${isActive(it.href) ? " active" : ""}`}
                          href={it.href}
                          role="menuitem"
                        >
                          <span class="mega-item-row">
                            <span class="mega-item-label">{it.label}</span>
                            <span class="mega-item-arr" aria-hidden="true">→</span>
                          </span>
                          <span class="mega-item-desc">{it.desc}</span>
                        </a>
                      ) : (
                        <div class="mega-item is-dimmed" aria-disabled="true">
                          <span class="mega-item-row">
                            <span class="mega-item-label">{it.label}</span>
                          </span>
                          <span class="mega-item-desc">{it.desc}</span>
                        </div>
                      )
                    )}
                  </div>
                ))}

                <aside class="mega-featured">
                  <div class="mega-featured-kicker">{g.featured.kicker}</div>
                  <div class="mega-featured-title">{g.featured.title}</div>
                  <p class="mega-featured-body">{g.featured.body}</p>
                  <a class="btn btn-primary mega-featured-cta" href={g.featured.ctaHref}>
                    {g.featured.ctaLabel} <span class="arr">→</span>
                  </a>
                </aside>
              </div>
            </div>
          </div>
        ))
      }

      <a class={`nav-link${isActive("/visit") ? " active" : ""}`} href="/visit">Come Visit</a>
      <a class={`nav-link${isActive("/who-is-jesus") ? " active" : ""}`} href="/who-is-jesus">Who is Jesus</a>
    </div>

    <div class="nav-cta">
      <a class="btn btn-ghost" href={GIVE_HREF} target="_blank" rel="noopener">Give</a>
      <a class="btn btn-primary" href="/visit">
        Plan a Visit
        <span class="arr">→</span>
      </a>
    </div>
  </div>
</nav>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 40px;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .brand-mark {
    width: 26px;
    height: 26px;
    border: 1.5px solid var(--ink);
    border-radius: 50%;
    position: relative;
    flex: none;
  }
  .brand-mark::before {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 1.5px;
    height: 60%;
    background: var(--ink);
    transform: translate(-50%, -50%);
  }
  .brand-mark::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 60%;
    height: 1.5px;
    background: var(--ink);
    transform: translate(-50%, -50%);
  }
  .brand-name {
    font-family: var(--display);
    font-size: 17px;
    font-weight: 600;
    letter-spacing: -0.012em;
    color: var(--ink);
  }
  .brand-name .accent {
    color: var(--accent);
  }

  /* Links row */
  .nav-links {
    display: flex;
    gap: 4px;
    align-items: center;
  }
  .nav-link {
    padding: 8px 14px;
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-2);
    border-radius: var(--radius-pill);
    letter-spacing: -0.005em;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .nav-link:hover {
    color: var(--ink);
    background: var(--bg-2);
  }
  .nav-link.active {
    color: var(--ink);
    background: var(--bg-2);
  }

  /* Dropdown trigger is a <button> for a11y; strip native chrome to match links */
  .nav-trigger {
    background: transparent;
    border: 0;
    cursor: default;
    font-family: inherit;
  }
  .caret {
    width: 8px;
    height: 8px;
    border-right: 1.4px solid currentColor;
    border-bottom: 1.4px solid currentColor;
    transform: rotate(45deg) translateY(-1px);
    opacity: 0.5;
    transition: transform 200ms ease;
  }

  /* -------------------------------------------------------------------------
   * MEGA PANEL — full-bleed, anchored to .nav (which is the positioned/sticky
   * containing block). .nav-item is NOT positioned, so the panel resolves to
   * .nav and spans left:0/right:0 (full width, no 100vw / no negative margins).
   * Opens on hover / focus-within of its .nav-item. Zero JS.
   * ----------------------------------------------------------------------- */
  .nav-item {
    /* intentionally static — lets .mega anchor to .nav, not the item */
  }
  .mega {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    z-index: 60;
    background: var(--bg);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line-strong);
    box-shadow: var(--shadow-dropdown);
    opacity: 0;
    visibility: hidden;
    transform: translateY(6px);
    transition: opacity 180ms ease, transform 180ms ease, visibility 180ms;
  }
  /* Hover-bridge: transparent strip from the panel up across the bar's lower
     padding, so the cursor keeps .nav-item:hover while descending from the
     trigger into the panel. Only present while this item's panel is open. */
  .mega::before {
    content: "";
    position: absolute;
    bottom: 100%;
    left: 0;
    right: 0;
    height: 16px;
  }
  .nav-item:hover .mega,
  .nav-item:focus-within .mega {
    opacity: 1;
    visibility: visible;
    transform: none;
  }
  .nav-item:hover .caret,
  .nav-item:focus-within .caret {
    transform: rotate(225deg) translateY(1px);
  }

  .mega-inner {
    max-width: 1440px;
    margin: 0 auto;
    padding: 36px 40px; /* 40px gutter matches .nav-inner so columns align under the bar */
    display: grid;
    gap: 36px;
  }
  /* one 1fr per content column + a 0.9fr featured rail */
  .mega-inner.cols-2 {
    grid-template-columns: repeat(2, 1fr) 0.9fr;
  }
  .mega-inner.cols-3 {
    grid-template-columns: repeat(3, 1fr) 0.9fr;
  }

  .mega-col {
    display: flex;
    flex-direction: column;
  }
  .mega-heading {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--ink-4);
    padding-bottom: 10px;
  }

  .mega-item {
    display: block;
    padding: 10px 12px;
    border-radius: 8px;
    color: inherit;
    transition: background 140ms ease;
  }
  .mega-item-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .mega-item-label {
    font-size: 15px;
    font-weight: 500;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .mega-item-arr {
    color: var(--accent);
    font-size: 13px;
    opacity: 0.55;
    transition: opacity 140ms ease;
  }
  .mega-item-desc {
    display: block;
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--ink-3);
    margin-top: 3px;
  }
  a.mega-item:hover,
  .mega-item.active {
    background: var(--bg-2);
  }
  a.mega-item:hover .mega-item-arr,
  .mega-item.active .mega-item-arr {
    opacity: 1;
  }
  /* Dimmed (unbuilt route): non-clickable, muted, no arrow, no hover bg. */
  .mega-item.is-dimmed {
    cursor: default;
  }
  .mega-item.is-dimmed .mega-item-label {
    color: var(--ink-4);
  }

  /* Featured rail */
  .mega-featured {
    background: var(--bg-2);
    border-radius: 10px;
    padding: 24px;
    display: flex;
    flex-direction: column;
  }
  .mega-featured-kicker {
    font-family: var(--mono);
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.09em;
    color: var(--ink-4);
    padding-bottom: 10px;
  }
  .mega-featured-title {
    font-family: var(--serif);
    font-size: 24px;
    line-height: 1.2;
    color: var(--ink);
  }
  .mega-featured-body {
    font-size: 13px;
    line-height: 1.55;
    color: var(--ink-3);
    margin: 10px 0 0;
  }
  .mega-featured-cta {
    margin-top: auto;
    align-self: flex-start;
  }

  /* CTA cluster */
  .nav-cta {
    display: flex;
    gap: 8px;
  }
  .nav-cta .btn {
    padding: 10px 18px;
    font-size: 13px;
  }

  /* TODO: mobile menu is a separate future task. For now, match the prior nav
     and hide the center links (and their mega panels) below 980px. */
  @media (max-width: 980px) {
    .nav-links {
      display: none;
    }
  }
</style>
